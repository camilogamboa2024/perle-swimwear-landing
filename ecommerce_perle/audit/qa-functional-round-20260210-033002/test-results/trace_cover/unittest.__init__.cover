    1: from .loader import makeSuite, getTestCaseNames, findTestCases
       
       # deprecated
    1: _TextTestResult = TextTestResult
       
       
       # There are no tests here, so don't try to run anything discovered from
       # introspecting the symbols (e.g. FunctionTestCase). Instead, all our
       # tests come from within unittest.test.
    1: def load_tests(loader, tests, pattern):
           import os.path
           # top level directory cached on loader instance
           this_dir = os.path.dirname(__file__)
           return loader.discover(start_dir=this_dir, pattern=pattern)
       
       
       # Lazy import of IsolatedAsyncioTestCase from .async_case
       # It imports asyncio, which is relatively heavy, but most tests
       # do not need it.
       
    1: def __dir__():
           return globals().keys() | {'IsolatedAsyncioTestCase'}
       
    1: def __getattr__(name):
    1:     if name == 'IsolatedAsyncioTestCase':
               global IsolatedAsyncioTestCase
               from .async_case import IsolatedAsyncioTestCase
               return IsolatedAsyncioTestCase
    1:     raise AttributeError(f"module {__name__!r} has no attribute {name!r}")
