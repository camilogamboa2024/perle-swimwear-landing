    2: class IntDumper(Dumper):
    1:     def dump(self, obj: Any) -> Buffer | None:
               raise TypeError(
                   f"{type(self).__name__} is a dispatcher to other dumpers:"
                   " dump() is not supposed to be called"
               )
       
    1:     def get_key(self, obj: int, format: PyFormat) -> type:
               return self.upgrade(obj, format).cls
       
    1:     _int2_dumper = Int2Dumper(Int2)
    1:     _int4_dumper = Int4Dumper(Int4)
    1:     _int8_dumper = Int8Dumper(Int8)
    1:     _int_numeric_dumper = IntNumericDumper(IntNumeric)
       
    1:     def upgrade(self, obj: int, format: PyFormat) -> Dumper:
               if -(2**31) <= obj < 2**31:
                   if -(2**15) <= obj < 2**15:
                       return self._int2_dumper
                   else:
                       return self._int4_dumper
               elif -(2**63) <= obj < 2**63:
                   return self._int8_dumper
               else:
                   return self._int_numeric_dumper
       
       
