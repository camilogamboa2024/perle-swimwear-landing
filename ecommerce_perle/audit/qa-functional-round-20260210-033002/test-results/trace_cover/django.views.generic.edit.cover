       )
       
       
    2: class FormMixin(ContextMixin):
    1:     """Provide a way to show and handle a form in a request."""
       
    1:     initial = {}
    1:     form_class = None
    1:     success_url = None
    1:     prefix = None
       
    1:     def get_initial(self):
               """Return the initial data to use for forms on this view."""
               return self.initial.copy()
       
    1:     def get_prefix(self):
               """Return the prefix to use for forms."""
               return self.prefix
       
    1:     def get_form_class(self):
               """Return the form class to use."""
               return self.form_class
       
    1:     def get_form(self, form_class=None):
               """Return an instance of the form to be used in this view."""
               if form_class is None:
                   form_class = self.get_form_class()
               return form_class(**self.get_form_kwargs())
       
    1:     def get_form_kwargs(self):
               """Return the keyword arguments for instantiating the form."""
               kwargs = {
                   "initial": self.get_initial(),
                   "prefix": self.get_prefix(),
               }
       
               if self.request.method in ("POST", "PUT"):
                   kwargs.update(
                       {
                           "data": self.request.POST,
                           "files": self.request.FILES,
                       }
                   )
               return kwargs
       
    1:     def get_success_url(self):
               """Return the URL to redirect to after processing a valid form."""
               if not self.success_url:
                   raise ImproperlyConfigured("No URL to redirect to. Provide a success_url.")
               return str(self.success_url)  # success_url may be lazy
       
    1:     def form_valid(self, form):
               """If the form is valid, redirect to the supplied URL."""
               return HttpResponseRedirect(self.get_success_url())
       
    1:     def form_invalid(self, form):
               """If the form is invalid, render the invalid form."""
               return self.render_to_response(self.get_context_data(form=form))
       
    1:     def get_context_data(self, **kwargs):
               """Insert the form into the context dict."""
               if "form" not in kwargs:
                   kwargs["form"] = self.get_form()
               return super().get_context_data(**kwargs)
       
       
    2: class ModelFormMixin(FormMixin, SingleObjectMixin):
    1:     """Provide a way to show and handle a ModelForm in a request."""
       
    1:     fields = None
       
    1:     def get_form_class(self):
               """Return the form class to use in this view."""
               if self.fields is not None and self.form_class:
                   raise ImproperlyConfigured(
                       "Specifying both 'fields' and 'form_class' is not permitted."
                   )
               if self.form_class:
                   return self.form_class
               else:
                   if self.model is not None:
                       # If a model has been explicitly provided, use it
                       model = self.model
                   elif getattr(self, "object", None) is not None:
                       # If this view is operating on a single object, use
                       # the class of that object
                       model = self.object.__class__
                   else:
                       # Try to get a queryset and extract the model class
                       # from that
                       model = self.get_queryset().model
       
                   if self.fields is None:
                       raise ImproperlyConfigured(
                           "Using ModelFormMixin (base class of %s) without "
                           "the 'fields' attribute is prohibited." % self.__class__.__name__
                       )
       
                   return model_forms.modelform_factory(model, fields=self.fields)
       
    1:     def get_form_kwargs(self):
               """Return the keyword arguments for instantiating the form."""
               kwargs = super().get_form_kwargs()
               if hasattr(self, "object"):
                   kwargs.update({"instance": self.object})
               return kwargs
       
    1:     def get_success_url(self):
               """Return the URL to redirect to after processing a valid form."""
               if self.success_url:
                   url = self.success_url.format(**self.object.__dict__)
               else:
                   try:
                       url = self.object.get_absolute_url()
                   except AttributeError:
                       raise ImproperlyConfigured(
                           "No URL to redirect to.  Either provide a url or define"
                           " a get_absolute_url method on the Model."
                       )
               return url
       
    1:     def form_valid(self, form):
               """If the form is valid, save the associated model."""
               self.object = form.save()
               return super().form_valid(form)
       
       
    2: class ProcessFormView(View):
    1:     """Render a form on GET and processes it on POST."""
       
    1:     def get(self, request, *args, **kwargs):
               """Handle GET requests: instantiate a blank version of the form."""
               return self.render_to_response(self.get_context_data())
       
    1:     def post(self, request, *args, **kwargs):
               """
               Handle POST requests: instantiate a form instance with the passed
               POST variables and then check if it's valid.
               """
               form = self.get_form()
               if form.is_valid():
                   return self.form_valid(form)
               else:
                   return self.form_invalid(form)
       
           # PUT is a valid HTTP verb for creating (with a known URL) or editing an
           # object, note that browsers only support POST for now.
    1:     def put(self, *args, **kwargs):
               return self.post(*args, **kwargs)
       
       
    2: class BaseFormView(FormMixin, ProcessFormView):
    1:     """A base view for displaying a form."""
       
       
    2: class FormView(TemplateResponseMixin, BaseFormView):
    1:     """A view for displaying a form and rendering a template response."""
       
       
    2: class BaseCreateView(ModelFormMixin, ProcessFormView):
    1:     """
           Base view for creating a new object instance.
       
           This requires subclassing to provide a response mixin.
           """
       
    1:     def get(self, request, *args, **kwargs):
               self.object = None
               return super().get(request, *args, **kwargs)
       
    1:     def post(self, request, *args, **kwargs):
               self.object = None
               return super().post(request, *args, **kwargs)
       
       
    2: class CreateView(SingleObjectTemplateResponseMixin, BaseCreateView):
    1:     """
           View for creating a new object, with a response rendered by a template.
           """
       
    1:     template_name_suffix = "_form"
       
       
    2: class BaseUpdateView(ModelFormMixin, ProcessFormView):
    1:     """
           Base view for updating an existing object.
       
           This requires subclassing to provide a response mixin.
           """
       
    1:     def get(self, request, *args, **kwargs):
               self.object = self.get_object()
               return super().get(request, *args, **kwargs)
       
    1:     def post(self, request, *args, **kwargs):
               self.object = self.get_object()
               return super().post(request, *args, **kwargs)
       
       
    2: class UpdateView(SingleObjectTemplateResponseMixin, BaseUpdateView):
    1:     """View for updating an object, with a response rendered by a template."""
       
    1:     template_name_suffix = "_form"
       
       
    2: class DeletionMixin:
    1:     """Provide the ability to delete objects."""
       
    1:     success_url = None
       
    1:     def delete(self, request, *args, **kwargs):
               """
               Call the delete() method on the fetched object and then redirect to the
               success URL.
               """
               self.object = self.get_object()
               success_url = self.get_success_url()
               self.object.delete()
               return HttpResponseRedirect(success_url)
       
           # Add support for browsers which only accept GET and POST for now.
    1:     def post(self, request, *args, **kwargs):
               return self.delete(request, *args, **kwargs)
       
    1:     def get_success_url(self):
               if self.success_url:
                   return self.success_url.format(**self.object.__dict__)
               else:
                   raise ImproperlyConfigured("No URL to redirect to. Provide a success_url.")
       
       
    2: class BaseDeleteView(DeletionMixin, FormMixin, BaseDetailView):
    1:     """
           Base view for deleting an object.
       
           This requires subclassing to provide a response mixin.
           """
       
    1:     form_class = Form
       
    1:     def post(self, request, *args, **kwargs):
               # Set self.object before the usual form processing flow.
               # Inlined because having DeletionMixin as the first base, for
               # get_success_url(), makes leveraging super() with ProcessFormView
               # overly complex.
               self.object = self.get_object()
               form = self.get_form()
               if form.is_valid():
                   return self.form_valid(form)
               else:
                   return self.form_invalid(form)
       
    1:     def form_valid(self, form):
               success_url = self.get_success_url()
               self.object.delete()
               return HttpResponseRedirect(success_url)
       
       
    2: class DeleteView(SingleObjectTemplateResponseMixin, BaseDeleteView):
    1:     """
           View for deleting an object retrieved with self.get_object(), with a
           response rendered by a template.
           """
       
    1:     template_name_suffix = "_confirm_delete"
