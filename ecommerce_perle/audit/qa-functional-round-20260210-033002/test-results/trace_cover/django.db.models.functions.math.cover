    2: class Cot(NumericOutputFieldMixin, Transform):
    1:     function = "COT"
    1:     lookup_name = "cot"
       
    1:     def as_oracle(self, compiler, connection, **extra_context):
               return super().as_sql(
                   compiler, connection, template="(1 / TAN(%(expressions)s))", **extra_context
               )
       
       
    2: class Degrees(NumericOutputFieldMixin, Transform):
    1:     function = "DEGREES"
    1:     lookup_name = "degrees"
       
    1:     def as_oracle(self, compiler, connection, **extra_context):
               return super().as_sql(
                   compiler,
                   connection,
                   template="((%%(expressions)s) * 180 / %s)" % math.pi,
                   **extra_context,
               )
       
       
