    1: def dependency_ordered(test_databases, dependencies):
           """
           Reorder test_databases into an order that honors the dependencies
           described in TEST[DEPENDENCIES].
           """
    1:     ordered_test_databases = []
    1:     resolved_databases = set()
       
           # Maps db signature to dependencies of all its aliases
    1:     dependencies_map = {}
       
           # Check that no database depends on its own alias
    2:     for sig, (_, aliases) in test_databases:
    1:         all_deps = set()
    2:         for alias in aliases:
    1:             all_deps.update(dependencies.get(alias, []))
    1:         if not all_deps.isdisjoint(aliases):
                   raise ImproperlyConfigured(
                       "Circular dependency: databases %r depend on each other, "
                       "but are aliases." % aliases
                   )
    1:         dependencies_map[sig] = all_deps
       
    2:     while test_databases:
    1:         changed = False
    1:         deferred = []
       
               # Try to find a DB that has all its dependencies met
    2:         for signature, (db_name, aliases) in test_databases:
    1:             if dependencies_map[signature].issubset(resolved_databases):
    1:                 resolved_databases.update(aliases)
    1:                 ordered_test_databases.append((signature, (db_name, aliases)))
    1:                 changed = True
                   else:
                       deferred.append((signature, (db_name, aliases)))
       
    1:         if not changed:
                   raise ImproperlyConfigured("Circular dependency in TEST[DEPENDENCIES]")
    1:         test_databases = deferred
    1:     return ordered_test_databases
       
       
    1: def get_unique_databases_and_mirrors(aliases=None):
           """
           Figure out which databases actually need to be created.
       
           Deduplicate entries in DATABASES that correspond the same database or are
           configured as test mirrors.
       
           Return two values:
           - test_databases: ordered mapping of signatures to (name, list of aliases)
                             where all aliases share the same underlying database.
           - mirrored_aliases: mapping of mirror aliases to original aliases.
           """
    1:     if aliases is None:
               aliases = connections
    1:     mirrored_aliases = {}
    1:     test_databases = {}
    1:     dependencies = {}
    1:     default_sig = connections[DEFAULT_DB_ALIAS].creation.test_db_signature()
       
    2:     for alias in connections:
    1:         connection = connections[alias]
    1:         test_settings = connection.settings_dict["TEST"]
       
    1:         if test_settings["MIRROR"]:
                   # If the database is marked as a test mirror, save the alias.
                   mirrored_aliases[alias] = test_settings["MIRROR"]
    1:         elif alias in aliases:
                   # Store a tuple with DB parameters that uniquely identify it.
                   # If we have two aliases with the same values for that tuple,
                   # we only need to create the test database once.
    2:             item = test_databases.setdefault(
    1:                 connection.creation.test_db_signature(),
    1:                 (connection.settings_dict["NAME"], []),
                   )
                   # The default database must be the first because data migrations
                   # use the default alias by default.
    1:             if alias == DEFAULT_DB_ALIAS:
    1:                 item[1].insert(0, alias)
                   else:
                       item[1].append(alias)
       
    1:             if "DEPENDENCIES" in test_settings:
                       dependencies[alias] = test_settings["DEPENDENCIES"]
                   else:
                       if (
    1:                     alias != DEFAULT_DB_ALIAS
                           and connection.creation.test_db_signature() != default_sig
                       ):
                           dependencies[alias] = test_settings.get(
                               "DEPENDENCIES", [DEFAULT_DB_ALIAS]
                           )
       
    1:     test_databases = dict(dependency_ordered(test_databases.items(), dependencies))
    1:     return test_databases, mirrored_aliases
       
       
    1: def teardown_databases(old_config, verbosity, parallel=0, keepdb=False):
