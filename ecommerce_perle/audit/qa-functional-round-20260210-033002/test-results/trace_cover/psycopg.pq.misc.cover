    1: from __future__ import annotations
       
    1: import os
    1: import re
    1: import sys
    1: import logging
    1: import ctypes.util
    1: from typing import NamedTuple
    1: from pathlib import Path
    1: from functools import cache
       
    1: from . import abc
    1: from ._enums import ConnStatus, PipelineStatus, TransactionStatus
       
    1: logger = logging.getLogger("psycopg.pq")
       
    1: OK = ConnStatus.OK
       
       
    2: class PGnotify(NamedTuple):
    1:     relname: bytes
    1:     be_pid: int
    1:     extra: bytes
       
       
