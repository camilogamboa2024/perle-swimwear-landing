    1: import functools
    1: from importlib import import_module
       
    1: from django.core.exceptions import ViewDoesNotExist
    1: from django.utils.module_loading import module_has_submodule
       
       
    2: @functools.cache
    2: def get_callable(lookup_view):
           """
           Return a callable corresponding to lookup_view.
           * If lookup_view is already a callable, return it.
           * If lookup_view is a string import path that can be resolved to a callable,
             import that callable and return it, otherwise raise an exception
             (ImportError or ViewDoesNotExist).
           """
    5:     if callable(lookup_view):
    4:         return lookup_view
       
    1:     if not isinstance(lookup_view, str):
               raise ViewDoesNotExist(
                   "'%s' is not a callable or a dot-notation path" % lookup_view
               )
       
    1:     mod_name, func_name = get_mod_func(lookup_view)
    1:     if not func_name:  # No '.' in lookup_view
               raise ImportError(
                   "Could not import '%s'. The path must be fully qualified." % lookup_view
               )
       
    1:     try:
    1:         mod = import_module(mod_name)
           except ImportError:
               parentmod, submod = get_mod_func(mod_name)
               if submod and not module_has_submodule(import_module(parentmod), submod):
                   raise ViewDoesNotExist(
                       "Could not import '%s'. Parent module %s does not exist."
                       % (lookup_view, mod_name)
                   )
               else:
                   raise
           else:
    1:         try:
    1:             view_func = getattr(mod, func_name)
               except AttributeError:
                   raise ViewDoesNotExist(
                       "Could not import '%s'. View does not exist in module %s."
                       % (lookup_view, mod_name)
                   )
               else:
    1:             if not callable(view_func):
                       raise ViewDoesNotExist(
                           "Could not import '%s.%s'. View is not callable."
                           % (mod_name, func_name)
                       )
    1:             return view_func
       
       
    1: def get_mod_func(callback):
           # Convert 'django.views.news.stories.story_detail' to
           # ['django.views.news.stories', 'story_detail']
    1:     try:
    1:         dot = callback.rindex(".")
           except ValueError:
               return callback, ""
    1:     return callback[:dot], callback[dot + 1 :]
