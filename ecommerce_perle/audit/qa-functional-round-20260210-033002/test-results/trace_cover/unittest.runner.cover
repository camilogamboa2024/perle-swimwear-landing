    1:     def addUnexpectedSuccess(self, test):
               super(TextTestResult, self).addUnexpectedSuccess(test)
               if self.showAll:
                   self.stream.writeln("unexpected success")
                   self.stream.flush()
               elif self.dots:
                   self.stream.write("u")
