    2: class CartStockValidationTest(TestCase):
    1:     def setUp(self):
    2:         self.client = Client(enforce_csrf_checks=True)
    2:         category = Category.objects.create(name='Stock', slug='stock')
    2:         product = Product.objects.create(name='Stock Product', slug='stock-product', category=category, description='x')
    4:         self.variant = ProductVariant.objects.create(
    2:             product=product,
    2:             sku='SKU-STOCK-1',
    2:             size='M',
    2:             color='Negro',
    2:             price_cop=100000,
    2:             is_active=True,
               )
    2:         StockLevel.objects.update_or_create(variant=self.variant, defaults={'available': 2})
       
    1:     def _csrf_headers(self):
    2:         response = self.client.get('/')
    2:         token = response.cookies.get('csrftoken').value
    2:         return {'HTTP_X_CSRFTOKEN': token}
       
    1:     def test_add_above_stock_returns_400_and_does_not_create_item(self):
    1:         headers = self._csrf_headers()
    4:         response = self.client.post(
    1:             '/api/cart/items/',
    1:             data=json.dumps({'variant_id': self.variant.id, 'quantity': 3}),
    1:             content_type='application/json',
    1:             **headers,
               )
    1:         self.assertEqual(response.status_code, 400)
    1:         self.assertIn('stock insuficiente', response.json().get('error', '').lower())
       
    1:         cart_response = self.client.get('/api/cart/')
    1:         self.assertEqual(cart_response.status_code, 200)
    1:         self.assertEqual(cart_response.json().get('items', []), [])
       
    1:     def test_patch_above_stock_returns_400_and_keeps_previous_quantity(self):
    1:         headers = self._csrf_headers()
    4:         add_response = self.client.post(
    1:             '/api/cart/items/',
    1:             data=json.dumps({'variant_id': self.variant.id, 'quantity': 1}),
    1:             content_type='application/json',
    1:             **headers,
               )
    1:         self.assertEqual(add_response.status_code, 201)
    1:         item_id = add_response.json()['items'][0]['id']
       
    4:         patch_response = self.client.patch(
    1:             f'/api/cart/items/{item_id}/',
    1:             data=json.dumps({'quantity': 3}),
    1:             content_type='application/json',
    1:             **headers,
               )
    1:         self.assertEqual(patch_response.status_code, 400)
    1:         self.assertIn('stock insuficiente', patch_response.json().get('error', '').lower())
       
    1:         cart_response = self.client.get('/api/cart/')
    1:         self.assertEqual(cart_response.status_code, 200)
    1:         self.assertEqual(cart_response.json()['items'][0]['quantity'], 1)
       
       
    2: class AuthenticatedCustomerReuseTest(TestCase):
    1:     def setUp(self):
    2:         self.client = Client(HTTP_HOST='127.0.0.1')
    2:         self.User = get_user_model()
       
    1:     def test_guest_customer_with_same_email_is_reused_when_user_logs_in(self):
    2:         guest_customer = Customer.objects.create(
    1:             email='customer-reuse@example.com',
    1:             full_name='Guest Customer',
               )
    2:         user = self.User.objects.create_user(
    1:             username='reuse-user',
    1:             password='Pass12345!',
    1:             email='customer-reuse@example.com',
               )
    1:         self.client.login(username='reuse-user', password='Pass12345!')
       
    1:         response = self.client.get('/cart/')
    1:         self.assertEqual(response.status_code, 200)
       
    1:         guest_customer.refresh_from_db()
    1:         self.assertEqual(guest_customer.user_id, user.id)
    1:         self.assertEqual(Customer.objects.filter(email='customer-reuse@example.com').count(), 1)
       
    1:     def test_email_collision_with_other_linked_customer_uses_fallback_email(self):
    2:         owner = self.User.objects.create_user(
    1:             username='owner-user',
    1:             password='Pass12345!',
    1:             email='shared-customer@example.com',
               )
    2:         Customer.objects.create(
    1:             user=owner,
    1:             email='shared-customer@example.com',
    1:             full_name='Owner Customer',
               )
    2:         second_user = self.User.objects.create_user(
    1:             username='second-user',
    1:             password='Pass12345!',
    1:             email='shared-customer@example.com',
               )
    1:         self.client.login(username='second-user', password='Pass12345!')
       
    1:         response = self.client.get('/cart/')
    1:         self.assertEqual(response.status_code, 200)
       
    1:         second_customer = Customer.objects.get(user=second_user)
    1:         self.assertNotEqual(second_customer.email, 'shared-customer@example.com')
    1:         self.assertIn(f'user-{second_user.id}', second_customer.email)
