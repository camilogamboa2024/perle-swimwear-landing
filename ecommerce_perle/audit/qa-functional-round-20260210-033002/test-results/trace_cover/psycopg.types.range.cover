    1:     def __ge__(self, other: Any) -> bool:
               return self == other or self > other  # type: ignore
       
    1:     def __getstate__(self) -> dict[str, Any]:
               return {
                   slot: getattr(self, slot) for slot in self.__slots__ if hasattr(self, slot)
               }
       
    1:     def __setstate__(self, state: dict[str, Any]) -> None:
               for slot, value in state.items():
                   setattr(self, slot, value)
       
       
