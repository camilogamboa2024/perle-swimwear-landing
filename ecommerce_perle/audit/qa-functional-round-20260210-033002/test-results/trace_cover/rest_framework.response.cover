           # Allow generic typing checking for responses.
    1:     def __class_getitem__(cls, *args, **kwargs):
               return cls
       
    2:     @property
    2:     def rendered_content(self):
   23:         renderer = getattr(self, 'accepted_renderer', None)
   23:         accepted_media_type = getattr(self, 'accepted_media_type', None)
   23:         context = getattr(self, 'renderer_context', None)
       
   23:         assert renderer, ".accepted_renderer not set on Response"
   23:         assert accepted_media_type, ".accepted_media_type not set on Response"
   23:         assert context is not None, ".renderer_context not set on Response"
   23:         context['response'] = self
       
   23:         media_type = renderer.media_type
   23:         charset = renderer.charset
   23:         content_type = self.content_type
       
   23:         if content_type is None and charset is not None:
                   content_type = f"{media_type}; charset={charset}"
   23:         elif content_type is None:
