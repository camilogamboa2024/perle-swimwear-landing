    1: def exception_handler(exc, context):
           """
           Returns the response that should be used for any given exception.
       
           By default we handle the REST framework `APIException`, and also
           Django's built-in `Http404` and `PermissionDenied` exceptions.
       
           Any unhandled exceptions may return `None`, which will cause a 500 error
           to be raised.
           """
    4:     if isinstance(exc, Http404):
               exc = exceptions.NotFound(*(exc.args))
    4:     elif isinstance(exc, PermissionDenied):
               exc = exceptions.PermissionDenied(*(exc.args))
       
    4:     if isinstance(exc, exceptions.APIException):
    4:         headers = {}
    4:         if getattr(exc, 'auth_header', None):
                   headers['WWW-Authenticate'] = exc.auth_header
    4:         if getattr(exc, 'wait', None):
                   headers['Retry-After'] = '%d' % exc.wait
       
    4:         if isinstance(exc.detail, (list, dict)):
                   data = exc.detail
               else:
    4:             data = {'detail': exc.detail}
       
    4:         set_rollback()
    4:         return Response(data, status=exc.status_code, headers=headers)
       
           return None
       
       
