    1: """
       psycopg -- PostgreSQL database adapter for Python
       """
       
       # Copyright (C) 2020 The Psycopg Team
       
    1: import logging
       
    1: from . import pq  # noqa: F401 import early to stabilize side effects
    1: from . import dbapi20, postgres, types
    1: from ._tpc import Xid
    1: from .copy import AsyncCopy, Copy
    1: from ._enums import IsolationLevel
    1: from .cursor import Cursor
    1: from .errors import DatabaseError, DataError, Error, IntegrityError, InterfaceError
    1: from .errors import InternalError, NotSupportedError, OperationalError
    1: from .errors import ProgrammingError, Warning
    1: from ._column import Column
    1: from .dbapi20 import BINARY, DATETIME, NUMBER, ROWID, STRING, Binary, Date
    1: from .dbapi20 import DateFromTicks, Time, TimeFromTicks, Timestamp, TimestampFromTicks
    1: from .version import __version__ as __version__  # noqa: F401
    1: from ._pipeline import Pipeline
    1: from .connection import Connection
    1: from .raw_cursor import AsyncRawCursor, AsyncRawServerCursor, RawCursor, RawServerCursor
    1: from .transaction import AsyncTransaction, Rollback, Transaction
    1: from .cursor_async import AsyncCursor
    1: from ._capabilities import Capabilities, capabilities
    1: from .client_cursor import AsyncClientCursor, ClientCursor
    1: from ._server_cursor import ServerCursor
    1: from ._pipeline_async import AsyncPipeline
    1: from ._connection_base import BaseConnection, Notify
    1: from ._connection_info import ConnectionInfo
    1: from .connection_async import AsyncConnection
    1: from ._server_cursor_async import AsyncServerCursor
       
       # Set the logger to a quiet default, can be enabled if needed
    1: if (logger := logging.getLogger("psycopg")).level == logging.NOTSET:
    1:     logger.setLevel(logging.WARNING)
       
       # DBAPI compliance
    1: connect = Connection.connect
    1: apilevel = "2.0"
    1: threadsafety = 2
    1: paramstyle = "pyformat"
       
       # register default adapters for PostgreSQL
    1: adapters = postgres.adapters  # exposed by the package
    1: postgres.register_default_types(adapters.types)
    1: postgres.register_default_adapters(adapters)
       
       # After the default ones, because these can deal with the bytea oid better
    1: dbapi20.register_dbapi20_adapters(adapters)
       
       # Must come after all the types have been registered
    1: types.array.register_all_arrays(adapters)
       
       # Note: defining the exported methods helps both Sphynx in documenting that
       # this is the canonical place to obtain them and should be used by MyPy too,
       # so that function signatures are consistent with the documentation.
    1: __all__ = [
           "AsyncClientCursor",
           "AsyncConnection",
           "AsyncCopy",
           "AsyncCursor",
           "AsyncPipeline",
           "AsyncRawCursor",
           "AsyncRawServerCursor",
           "AsyncServerCursor",
           "AsyncTransaction",
           "BaseConnection",
           "Capabilities",
           "capabilities",
           "ClientCursor",
           "Column",
           "Connection",
           "ConnectionInfo",
           "Copy",
           "Cursor",
           "IsolationLevel",
           "Notify",
           "Pipeline",
           "RawCursor",
           "RawServerCursor",
           "Rollback",
           "ServerCursor",
           "Transaction",
           "Xid",
           # DBAPI exports
           "connect",
           "apilevel",
           "threadsafety",
           "paramstyle",
           "Warning",
           "Error",
           "InterfaceError",
           "DatabaseError",
           "DataError",
           "OperationalError",
           "IntegrityError",
           "InternalError",
           "ProgrammingError",
           "NotSupportedError",
           # DBAPI type constructors and singletons
           "Binary",
           "Date",
           "DateFromTicks",
           "Time",
           "TimeFromTicks",
           "Timestamp",
           "TimestampFromTicks",
           "BINARY",
           "DATETIME",
           "NUMBER",
           "ROWID",
           "STRING",
       ]
