    1: def register_default_adapters(context: AdaptContext) -> None:
    1:     from .types import array, bool, composite, datetime, enum, json, multirange, net
    1:     from .types import none, numeric, numpy, range, string, uuid
       
    1:     array.register_default_adapters(context)
    1:     composite.register_default_adapters(context)
    1:     datetime.register_default_adapters(context)
    1:     enum.register_default_adapters(context)
    1:     json.register_default_adapters(context)
    1:     multirange.register_default_adapters(context)
    1:     net.register_default_adapters(context)
    1:     none.register_default_adapters(context)
    1:     range.register_default_adapters(context)
    1:     string.register_default_adapters(context)
    1:     uuid.register_default_adapters(context)
       
           # Both numpy Decimal and uint64 dumpers use the numeric oid, but the former
           # covers the entire numeric domain, whereas the latter only deals with
           # integers. For this reason, if we specify dumpers by oid, we want to make
           # sure to get the Decimal dumper. We enforce that by registering the
           # numeric dumpers last.
    1:     numpy.register_default_adapters(context)
    1:     bool.register_default_adapters(context)
    1:     numeric.register_default_adapters(context)
