    2: class BaseYearArchiveView(YearMixin, BaseDateListView):
    1:     """
           Base view for a list of objects published in a given year.
       
           This requires subclassing to provide a response mixin.
           """
       
    1:     date_list_period = "month"
    1:     make_object_list = False
       
    1:     def get_dated_items(self):
               """Return (date_list, items, extra_context) for this request."""
