    1:     SQLSTATE = ord("C")
    1:     MESSAGE_PRIMARY = ord("M")
    1:     MESSAGE_DETAIL = ord("D")
    1:     MESSAGE_HINT = ord("H")
    1:     STATEMENT_POSITION = ord("P")
    1:     INTERNAL_POSITION = ord("p")
    1:     INTERNAL_QUERY = ord("q")
    1:     CONTEXT = ord("W")
    1:     SCHEMA_NAME = ord("s")
    1:     TABLE_NAME = ord("t")
    1:     COLUMN_NAME = ord("c")
    1:     DATATYPE_NAME = ord("d")
    1:     CONSTRAINT_NAME = ord("n")
    1:     SOURCE_FILE = ord("F")
    1:     SOURCE_LINE = ord("L")
    1:     SOURCE_FUNCTION = ord("R")
       
       
    2: class Format(IntEnum):
    1:     """
           Enum representing the format of a query argument or return value.
       
           These values are only the ones managed by the libpq. `~psycopg` may also
           support automatically-chosen values: see `psycopg.adapt.PyFormat`.
           """
       
    1:     __module__ = "psycopg.pq"
       
    1:     TEXT = 0
    1:     """Text parameter."""
    1:     BINARY = 1
    1:     """Binary parameter."""
       
       
    2: class Trace(IntFlag):
    1:     """
           Enum to control tracing of the client/server communication.
           """
       
    1:     __module__ = "psycopg.pq"
       
    1:     SUPPRESS_TIMESTAMPS = 1
    1:     """Do not include timestamps in messages."""
       
    1:     REGRESS_MODE = 2
    1:     """Redact some fields, e.g. OIDs, from messages."""
