    1: "Thread-safe in-memory cache backend."
       
    1: import pickle
    1: import time
    1: from collections import OrderedDict
    1: from threading import Lock
       
    1: from django.core.cache.backends.base import DEFAULT_TIMEOUT, BaseCache
       
       # Global in-memory store of cache data. Keyed by name, to provide
       # multiple named local memory caches.
    1: _caches = {}
    1: _expire_info = {}
    1: _locks = {}
       
       
    2: class LocMemCache(BaseCache):
    1:     pickle_protocol = pickle.HIGHEST_PROTOCOL
       
    1:     def __init__(self, name, params):
    1:         super().__init__(params)
    1:         self._cache = _caches.setdefault(name, OrderedDict())
    1:         self._expire_info = _expire_info.setdefault(name, {})
    1:         self._lock = _locks.setdefault(name, Lock())
       
    1:     def add(self, key, value, timeout=DEFAULT_TIMEOUT, version=None):
               key = self.make_and_validate_key(key, version=version)
               pickled = pickle.dumps(value, self.pickle_protocol)
               with self._lock:
                   if self._has_expired(key):
                       self._set(key, pickled, timeout)
                       return True
                   return False
       
    1:     def get(self, key, default=None, version=None):
    5:         key = self.make_and_validate_key(key, version=version)
   10:         with self._lock:
    5:             if self._has_expired(key):
    1:                 self._delete(key)
    1:                 return default
    4:             pickled = self._cache[key]
    4:             self._cache.move_to_end(key, last=False)
    4:         return pickle.loads(pickled)
       
    1:     def _set(self, key, value, timeout=DEFAULT_TIMEOUT):
    5:         if len(self._cache) >= self._max_entries:
                   self._cull()
    5:         self._cache[key] = value
    5:         self._cache.move_to_end(key, last=False)
    5:         self._expire_info[key] = self.get_backend_timeout(timeout)
       
    1:     def set(self, key, value, timeout=DEFAULT_TIMEOUT, version=None):
    5:         key = self.make_and_validate_key(key, version=version)
    5:         pickled = pickle.dumps(value, self.pickle_protocol)
   10:         with self._lock:
    5:             self._set(key, pickled, timeout)
       
    1:     def touch(self, key, timeout=DEFAULT_TIMEOUT, version=None):
               key = self.make_and_validate_key(key, version=version)
               with self._lock:
                   if self._has_expired(key):
                       return False
                   self._expire_info[key] = self.get_backend_timeout(timeout)
                   return True
       
    1:     def incr(self, key, delta=1, version=None):
               key = self.make_and_validate_key(key, version=version)
               with self._lock:
                   if self._has_expired(key):
                       self._delete(key)
                       raise ValueError("Key '%s' not found" % key)
                   pickled = self._cache[key]
                   value = pickle.loads(pickled)
                   new_value = value + delta
                   pickled = pickle.dumps(new_value, self.pickle_protocol)
                   self._cache[key] = pickled
                   self._cache.move_to_end(key, last=False)
               return new_value
       
    1:     def has_key(self, key, version=None):
               key = self.make_and_validate_key(key, version=version)
               with self._lock:
                   if self._has_expired(key):
                       self._delete(key)
                       return False
                   return True
       
    1:     def _has_expired(self, key):
    5:         exp = self._expire_info.get(key, -1)
    5:         return exp is not None and exp <= time.time()
       
    1:     def _cull(self):
               if self._cull_frequency == 0:
                   self._cache.clear()
                   self._expire_info.clear()
               else:
                   count = len(self._cache) // self._cull_frequency
                   for i in range(count):
                       key, _ = self._cache.popitem()
                       del self._expire_info[key]
       
    1:     def _delete(self, key):
    1:         try:
    1:             del self._cache[key]
                   del self._expire_info[key]
    1:         except KeyError:
    1:             return False
               return True
       
    1:     def delete(self, key, version=None):
               key = self.make_and_validate_key(key, version=version)
               with self._lock:
                   return self._delete(key)
       
    1:     def clear(self):
               with self._lock:
                   self._cache.clear()
                   self._expire_info.clear()
