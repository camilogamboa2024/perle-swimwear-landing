    1:     impl = os.environ.get("PSYCOPG_IMPL", "").lower()
    1:     module = None
    1:     attempts: list[str] = []
       
    1:     def handle_error(name: str, e: Exception) -> None:
    1:         if not impl:
    1:             msg = f"couldn't import psycopg '{name}' implementation: {e}"
    1:             attempts.append(msg)
               else:
                   msg = f"couldn't import requested psycopg '{name}' implementation: {e}"
                   raise ImportError(msg) from e
       
           # The best implementation: fast but requires the system libpq installed
    1:     if not impl or impl == "c":
    1:         try:
    1:             from psycopg_c import pq as module  # type: ignore
    1:         except Exception as e:
    1:             handle_error("c", e)
       
           # Second best implementation: fast and stand-alone
    1:     if not module and (not impl or impl == "binary"):
    1:         try:
    1:             from psycopg_binary import pq as module  # type: ignore
               except Exception as e:
                   handle_error("binary", e)
       
           # Pure Python implementation, slow and requires the system libpq installed.
    1:     if not module and (not impl or impl == "python"):
