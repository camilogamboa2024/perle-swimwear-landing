    1: from django.db import models
       
       
    2: class Category(models.Model):
    1:     name = models.CharField(max_length=80, unique=True)
    1:     slug = models.SlugField(max_length=90, unique=True, db_index=True)
       
    1:     def __str__(self):
               return self.name
       
       
    2: class Product(models.Model):
    1:     name = models.CharField(max_length=140)
    1:     slug = models.SlugField(unique=True, db_index=True)
    1:     category = models.ForeignKey(Category, on_delete=models.PROTECT, related_name='products')
    1:     description = models.TextField()
    1:     is_active = models.BooleanField(default=True, db_index=True)
    1:     created_at = models.DateTimeField(auto_now_add=True, db_index=True)
       
    2:     class Meta:
    1:         indexes = [models.Index(fields=['is_active', 'created_at'])]
       
    1:     def __str__(self):
               return self.name
       
       
    2: class ProductVariant(models.Model):
    1:     product = models.ForeignKey(Product, on_delete=models.CASCADE, related_name='variants')
    1:     sku = models.CharField(max_length=40, unique=True)
    1:     size = models.CharField(max_length=16, db_index=True)
    1:     color = models.CharField(max_length=32, db_index=True)
    1:     price_cop = models.PositiveIntegerField()
    1:     compare_at_price_cop = models.PositiveIntegerField(null=True, blank=True)
    1:     is_default = models.BooleanField(default=False)
    1:     is_active = models.BooleanField(default=True, db_index=True)
       
    2:     class Meta:
    1:         indexes = [models.Index(fields=['product', 'size', 'color'])]
       
    1:     def __str__(self):
               return f'{self.product.name} - {self.size}/{self.color}'
       
       
    2: class ProductImage(models.Model):
    1:     product = models.ForeignKey(Product, on_delete=models.CASCADE, related_name='images')
    1:     image_url = models.URLField()
    1:     alt_text = models.CharField(max_length=150)
    1:     sort_order = models.PositiveSmallIntegerField(default=0)
       
    2:     class Meta:
    1:         ordering = ['sort_order']
