    2: class DateTimeRangeContains(PostgresOperatorLookup):
    1:     """
           Lookup for Date/DateTimeRange containment to cast the rhs to the correct
           type.
           """
       
    1:     lookup_name = "contains"
    1:     postgres_operator = RangeOperators.CONTAINS
       
    1:     def process_rhs(self, compiler, connection):
               # Transform rhs value for db lookup.
               if isinstance(self.rhs, datetime.date):
                   value = models.Value(self.rhs)
                   self.rhs = value.resolve_expression(compiler.query)
               return super().process_rhs(compiler, connection)
       
    1:     def as_postgresql(self, compiler, connection):
               sql, params = super().as_postgresql(compiler, connection)
               # Cast the rhs if needed.
               cast_sql = ""
               if (
                   isinstance(self.rhs, models.Expression)
                   and self.rhs._output_field_or_none
                   and
                   # Skip cast if rhs has a matching range type.
                   not isinstance(
                       self.rhs._output_field_or_none, self.lhs.output_field.__class__
                   )
               ):
                   cast_internal_type = self.lhs.output_field.base_field.get_internal_type()
                   cast_sql = "::{}".format(connection.data_types.get(cast_internal_type))
               return "%s%s" % (sql, cast_sql), params
       
       
    1: DateRangeField.register_lookup(DateTimeRangeContains)
    1: DateTimeRangeField.register_lookup(DateTimeRangeContains)
       
       
    2: class RangeContainedBy(PostgresOperatorLookup):
    1:     lookup_name = "contained_by"
    1:     type_mapping = {
    1:         "smallint": "int4range",
    1:         "integer": "int4range",
    1:         "bigint": "int8range",
    1:         "double precision": "numrange",
    1:         "numeric": "numrange",
    1:         "date": "daterange",
    1:         "timestamp with time zone": "tstzrange",
           }
    1:     postgres_operator = RangeOperators.CONTAINED_BY
       
    1:     def process_rhs(self, compiler, connection):
               rhs, rhs_params = super().process_rhs(compiler, connection)
               # Ignore precision for DecimalFields.
               db_type = self.lhs.output_field.cast_db_type(connection).split("(")[0]
               cast_type = self.type_mapping[db_type]
               return "%s::%s" % (rhs, cast_type), rhs_params
       
    1:     def process_lhs(self, compiler, connection):
               lhs, lhs_params = super().process_lhs(compiler, connection)
               if isinstance(self.lhs.output_field, models.FloatField):
                   lhs = "%s::numeric" % lhs
               elif isinstance(self.lhs.output_field, models.SmallIntegerField):
                   lhs = "%s::integer" % lhs
               return lhs, lhs_params
       
    1:     def get_prep_lookup(self):
               return RangeField().get_prep_value(self.rhs)
       
       
    1: models.DateField.register_lookup(RangeContainedBy)
    1: models.DateTimeField.register_lookup(RangeContainedBy)
    1: models.IntegerField.register_lookup(RangeContainedBy)
    1: models.FloatField.register_lookup(RangeContainedBy)
    1: models.DecimalField.register_lookup(RangeContainedBy)
       
       
