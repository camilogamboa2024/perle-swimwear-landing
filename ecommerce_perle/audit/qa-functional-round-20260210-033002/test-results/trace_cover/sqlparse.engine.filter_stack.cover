    1: """filter"""
       
    1: from sqlparse import lexer
    1: from sqlparse.engine import grouping
    1: from sqlparse.engine.statement_splitter import StatementSplitter
    1: from sqlparse.exceptions import SQLParseError
    1: from sqlparse.filters import StripTrailingSemicolonFilter
       
       
    2: class FilterStack:
    1:     def __init__(self, strip_semicolon=False):
               self.preprocess = []
               self.stmtprocess = []
               self.postprocess = []
               self._grouping = False
               if strip_semicolon:
                   self.stmtprocess.append(StripTrailingSemicolonFilter())
       
    1:     def enable_grouping(self):
               self._grouping = True
       
    1:     def run(self, sql, encoding=None):
               try:
                   stream = lexer.tokenize(sql, encoding)
                   # Process token stream
                   for filter_ in self.preprocess:
                       stream = filter_.process(stream)
       
                   stream = StatementSplitter().process(stream)
       
                   # Output: Stream processed Statements
                   for stmt in stream:
                       if self._grouping:
                           stmt = grouping.group(stmt)
       
                       for filter_ in self.stmtprocess:
                           filter_.process(stmt)
       
                       for filter_ in self.postprocess:
                           stmt = filter_.process(stmt)
       
                       yield stmt
               except RecursionError as err:
                   raise SQLParseError('Maximum recursion depth exceeded') from err
