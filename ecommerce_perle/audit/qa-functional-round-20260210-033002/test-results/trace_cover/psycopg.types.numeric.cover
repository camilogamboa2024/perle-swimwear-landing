               return dump_decimal_to_numeric_binary(obj)
       
       
    2: class _MixedNumericDumper(Dumper, ABC):
    1:     """Base for dumper to dump int, decimal, numpy.integer to Postgres numeric
       
           Only used when looking up by oid.
           """
       
    1:     oid = _oids.NUMERIC_OID
       
           # If numpy is available, the dumped object might be a numpy integer too
    1:     int_classes: type | tuple[type, ...] = ()
       
    1:     def __init__(self, cls: type, context: AdaptContext | None = None):
               super().__init__(cls, context)
       
               # Verify if numpy is available. If it is, we might have to dump
               # its integers too.
               if not _MixedNumericDumper.int_classes:
                   if "numpy" in sys.modules:
                       import numpy
       
                       _MixedNumericDumper.int_classes = (int, numpy.integer)
                   else:
                       _MixedNumericDumper.int_classes = int
       
    2:     @abstractmethod
    2:     def dump(self, obj: Decimal | int | numpy.integer[Any]) -> Buffer | None: ...
       
       
    2: class NumericDumper(_MixedNumericDumper):
    1:     def dump(self, obj: Decimal | int | numpy.integer[Any]) -> Buffer | None:
               if isinstance(obj, self.int_classes):
                   return str(obj).encode()
               elif isinstance(obj, Decimal):
                   return dump_decimal_to_text(obj)
               else:
                   raise TypeError(
                       f"class {type(self).__name__} cannot dump {type(obj).__name__}"
                   )
       
       
    2: class NumericBinaryDumper(_MixedNumericDumper):
    1:     format = Format.BINARY
       
    1:     def dump(self, obj: Decimal | int | numpy.integer[Any]) -> Buffer | None:
               if type(obj) is int:
                   return dump_int_to_numeric_binary(obj)
               elif isinstance(obj, Decimal):
                   return dump_decimal_to_numeric_binary(obj)
               elif isinstance(obj, self.int_classes):
                   return dump_int_to_numeric_binary(int(obj))
               else:
                   raise TypeError(
                       f"class {type(self).__name__} cannot dump {type(obj).__name__}"
                   )
       
       
    1: def dump_decimal_to_text(obj: Decimal) -> bytes:
           if obj.is_nan():
               # cover NaN and sNaN
               return b"NaN"
           else:
               return str(obj).encode()
       
       
    1: def dump_decimal_to_numeric_binary(obj: Decimal) -> bytearray | bytes:
           sign, digits, exp = obj.as_tuple()
           if exp == "n" or exp == "N":
               return NUMERIC_NAN_BIN
           elif exp == "F":
               return NUMERIC_NINF_BIN if sign else NUMERIC_PINF_BIN
       
           # Weights of py digits into a pg digit according to their positions.
           # Starting with an index wi != 0 is equivalent to prepending 0's to
           # the digits tuple, but without really changing it.
           weights = (1000, 100, 10, 1)
           wi = 0
       
           ndigits = nzdigits = len(digits)
       
           # Find the last nonzero digit
           while nzdigits > 0 and digits[nzdigits - 1] == 0:
               nzdigits -= 1
       
           if exp <= 0:
               dscale = -exp
           else:
               dscale = 0
               # align the py digits to the pg digits if there's some py exponent
               ndigits += exp % DEC_DIGITS
       
           if not nzdigits:
               return _pack_numeric_head(0, 0, NUMERIC_POS, dscale)
       
           # Equivalent of 0-padding left to align the py digits to the pg digits
           # but without changing the digits tuple.
           if mod := ((ndigits - dscale) % DEC_DIGITS):
               wi = DEC_DIGITS - mod
               ndigits += wi
       
           tmp = nzdigits + wi
           out = bytearray(
               _pack_numeric_head(
                   tmp // DEC_DIGITS + (tmp % DEC_DIGITS and 1),  # ndigits
                   (ndigits + exp) // DEC_DIGITS - 1,  # weight
                   NUMERIC_NEG if sign else NUMERIC_POS,  # sign
                   dscale,
               )
           )
       
           pgdigit = 0
           for i in range(nzdigits):
               pgdigit += weights[wi] * digits[i]
               wi += 1
               if wi >= DEC_DIGITS:
                   out += pack_uint2(pgdigit)
                   pgdigit = wi = 0
       
           if pgdigit:
               out += pack_uint2(pgdigit)
       
           return out
       
       
    1: def dump_int_to_numeric_binary(obj: int) -> bytearray:
           ndigits = int(obj.bit_length() * BIT_PER_PGDIGIT) + 1
           out = bytearray(b"\x00\x00" * (ndigits + 4))
           if obj < 0:
               sign = NUMERIC_NEG
               obj = -obj
           else:
               sign = NUMERIC_POS
       
           out[:8] = _pack_numeric_head(ndigits, ndigits - 1, sign, 0)
           i = 8 + (ndigits - 1) * 2
           while obj:
               rem = obj % 10_000
               obj //= 10_000
               out[i : i + 2] = pack_uint2(rem)
               i -= 2
       
           return out
       
       
    1: def register_default_adapters(context: AdaptContext) -> None:
    1:     adapters = context.adapters
    1:     adapters.register_dumper(int, IntDumper)
    1:     adapters.register_dumper(int, IntBinaryDumper)
    1:     adapters.register_dumper(float, FloatDumper)
    1:     adapters.register_dumper(float, FloatBinaryDumper)
    1:     adapters.register_dumper(Int2, Int2Dumper)
    1:     adapters.register_dumper(Int4, Int4Dumper)
    1:     adapters.register_dumper(Int8, Int8Dumper)
    1:     adapters.register_dumper(IntNumeric, IntNumericDumper)
    1:     adapters.register_dumper(Oid, OidDumper)
       
           # The binary dumper is currently some 30% slower, so default to text
           # (see tests/scripts/testdec.py for a rough benchmark)
           # Also, must be after IntNumericDumper
    1:     adapters.register_dumper("decimal.Decimal", DecimalBinaryDumper)
    1:     adapters.register_dumper("decimal.Decimal", DecimalDumper)
       
           # Used only by oid, can take both int and Decimal as input
    1:     adapters.register_dumper(None, NumericBinaryDumper)
    1:     adapters.register_dumper(None, NumericDumper)
       
    1:     adapters.register_dumper(Float4, Float4Dumper)
    1:     adapters.register_dumper(Float8, FloatDumper)
    1:     adapters.register_dumper(Int2, Int2BinaryDumper)
    1:     adapters.register_dumper(Int4, Int4BinaryDumper)
    1:     adapters.register_dumper(Int8, Int8BinaryDumper)
    1:     adapters.register_dumper(Oid, OidBinaryDumper)
    1:     adapters.register_dumper(Float4, Float4BinaryDumper)
    1:     adapters.register_dumper(Float8, FloatBinaryDumper)
    1:     adapters.register_loader("int2", IntLoader)
    1:     adapters.register_loader("int4", IntLoader)
    1:     adapters.register_loader("int8", IntLoader)
    1:     adapters.register_loader("oid", IntLoader)
    1:     adapters.register_loader("int2", Int2BinaryLoader)
    1:     adapters.register_loader("int4", Int4BinaryLoader)
    1:     adapters.register_loader("int8", Int8BinaryLoader)
    1:     adapters.register_loader("oid", OidBinaryLoader)
    1:     adapters.register_loader("float4", FloatLoader)
    1:     adapters.register_loader("float8", FloatLoader)
    1:     adapters.register_loader("float4", Float4BinaryLoader)
    1:     adapters.register_loader("float8", Float8BinaryLoader)
    1:     adapters.register_loader("numeric", NumericLoader)
    1:     adapters.register_loader("numeric", NumericBinaryLoader)
