    2: class PercentStyle(object):
       
    1:     default_format = '%(message)s'
    1:     asctime_format = '%(asctime)s'
    1:     asctime_search = '%(asctime)'
    1:     validation_pattern = re.compile(r'%\(\w+\)[#0+ -]*(\*|\d+)?(\.(\*|\d+))?[diouxefgcrsa%]', re.I)
       
    1:     def __init__(self, fmt, *, defaults=None):
    2:         self._fmt = fmt or self.default_format
    2:         self._defaults = defaults
       
    1:     def usesTime(self):
