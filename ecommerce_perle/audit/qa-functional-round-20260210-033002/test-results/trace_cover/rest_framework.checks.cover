    1: from django.core.checks import Tags, Warning, register
       
       
    2: @register(Tags.compatibility)
    2: def pagination_system_check(app_configs, **kwargs):
    1:     errors = []
           # Use of default page size setting requires a default Paginator class
    1:     from rest_framework.settings import api_settings
    1:     if api_settings.PAGE_SIZE and not api_settings.DEFAULT_PAGINATION_CLASS:
               errors.append(
                   Warning(
                       "You have specified a default PAGE_SIZE pagination rest_framework setting, "
                       "without specifying also a DEFAULT_PAGINATION_CLASS.",
                       hint="The default for DEFAULT_PAGINATION_CLASS is None. "
                            "In previous versions this was PageNumberPagination. "
                            "If you wish to define PAGE_SIZE globally whilst defining "
                            "pagination_class on a per-view basis you may silence this check.",
                       id="rest_framework.W001"
                   )
               )
    1:     return errors
