               allow_empty = self.get_allow_empty()
               paginate_by = self.get_paginate_by(qs)
       
               if not allow_future:
                   now = timezone.now() if self.uses_datetime_field else timezone_today()
                   qs = qs.filter(**{"%s__lte" % date_field: now})
       
               if not allow_empty:
