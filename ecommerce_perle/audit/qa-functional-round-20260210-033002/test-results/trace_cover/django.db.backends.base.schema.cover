               return (
                   (
                       self.sql_alter_column_type
                       % {
                           "column": self.quote_name(new_field.column),
                           "type": new_type,
                           "collation": collate_sql,
                           "comment": comment_sql,
                       },
                       [],
                   ),
                   other_actions,
               )
       
