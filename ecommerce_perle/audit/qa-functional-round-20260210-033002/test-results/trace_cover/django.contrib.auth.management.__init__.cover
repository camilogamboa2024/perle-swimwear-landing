    1: """
       Creates permissions for all installed apps that need permissions.
       """
       
    1: import getpass
    1: import unicodedata
       
    1: from django.apps import apps as global_apps
    1: from django.contrib.auth import get_permission_codename
    1: from django.contrib.contenttypes.management import create_contenttypes
    1: from django.core import exceptions
    1: from django.db import DEFAULT_DB_ALIAS, router
       
       
    1: def _get_all_permissions(opts):
           """
           Return (codename, name) for all permissions in the given opts.
           """
   20:     return [*_get_builtin_permissions(opts), *opts.permissions]
       
       
    1: def _get_builtin_permissions(opts):
           """
           Return (codename, name) for all autogenerated permissions.
           By default, this is ('add', 'change', 'delete', 'view')
           """
   40:     perms = []
  200:     for action in opts.default_permissions:
  320:         perms.append(
  160:             (
  160:                 get_permission_codename(action, opts),
  160:                 "Can %s %s" % (action, opts.verbose_name_raw),
                   )
               )
   40:     return perms
       
       
    1: def create_permissions(
           app_config,
    1:     verbosity=2,
    1:     interactive=True,
    1:     using=DEFAULT_DB_ALIAS,
    1:     apps=global_apps,
           **kwargs,
       ):
    8:     if not app_config.models_module:
               return
       
    8:     try:
    8:         Permission = apps.get_model("auth", "Permission")
           except LookupError:
               return
    8:     if not router.allow_migrate_model(using, Permission):
               return
       
           # Ensure that contenttypes are created for this app. Needed if
           # 'django.contrib.auth' is in INSTALLED_APPS before
           # 'django.contrib.contenttypes'.
   32:     create_contenttypes(
    8:         app_config,
    8:         verbosity=verbosity,
    8:         interactive=interactive,
    8:         using=using,
    8:         apps=apps,
    8:         **kwargs,
           )
       
    8:     app_label = app_config.label
    8:     try:
    8:         app_config = apps.get_app_config(app_label)
    8:         ContentType = apps.get_model("contenttypes", "ContentType")
           except LookupError:
               return
       
    8:     models = list(app_config.get_models())
       
           # Grab all the ContentTypes.
   24:     ctypes = ContentType.objects.db_manager(using).get_for_models(
   16:         *models, for_concrete_models=False
           )
       
           # Find all the Permissions that have a content_type for a model we're
           # looking for.  We don't need to check for codenames since we already have
           # a list of the ones we're going to create.
   16:     all_perms = set(
    8:         Permission.objects.using(using)
   16:         .filter(
    8:             content_type__in=set(ctypes.values()),
               )
    8:         .values_list("content_type", "codename")
           )
       
    8:     perms = []
   28:     for model in models:
   20:         ctype = ctypes[model]
  100:         for codename, name in _get_all_permissions(model._meta):
   80:             if (ctype.pk, codename) not in all_perms:
   80:                 permission = Permission()
   80:                 permission._state.db = using
   80:                 permission.codename = codename
   80:                 permission.name = name
   80:                 permission.content_type = ctype
   80:                 perms.append(permission)
       
    8:     Permission.objects.using(using).bulk_create(perms)
    8:     if verbosity >= 2:
               for perm in perms:
                   print("Adding permission '%s'" % perm)
       
       
    1: def get_system_username():
           """
           Return the current system user's username, or an empty string if the
           username could not be determined.
           """
           try:
               result = getpass.getuser()
           except (ImportError, KeyError, OSError):
               # TODO: Drop ImportError and KeyError when dropping support for PY312.
               # KeyError (Python <3.13) or OSError (Python 3.13+) will be raised by
               # os.getpwuid() (called by getuser()) if there is no corresponding
               # entry in the /etc/passwd file (for example, in a very restricted
               # chroot environment).
               return ""
           return result
       
       
    1: def get_default_username(check_db=True, database=DEFAULT_DB_ALIAS):
           """
           Try to determine the current system user's username to use as a default.
       
           :param check_db: If ``True``, requires that the username does not match an
               existing ``auth.User`` (otherwise returns an empty string).
           :param database: The database where the unique check will be performed.
           :returns: The username, or an empty string if no username can be
               determined or the suggested username is already taken.
           """
           # This file is used in apps.py, it should not trigger models import.
           from django.contrib.auth import models as auth_app
       
           # If the User model has been swapped out, we can't make any assumptions
           # about the default user name.
           if auth_app.User._meta.swapped:
               return ""
       
           default_username = get_system_username()
           try:
               default_username = (
                   unicodedata.normalize("NFKD", default_username)
                   .encode("ascii", "ignore")
                   .decode("ascii")
                   .replace(" ", "")
                   .lower()
               )
           except UnicodeDecodeError:
               return ""
       
           # Run the username validator
           try:
               auth_app.User._meta.get_field("username").run_validators(default_username)
           except exceptions.ValidationError:
               return ""
       
           # Don't return the default username if it is already taken.
           if check_db and default_username:
               try:
                   auth_app.User._default_manager.db_manager(database).get(
                       username=default_username,
                   )
               except auth_app.User.DoesNotExist:
                   pass
               else:
                   return ""
           return default_username
