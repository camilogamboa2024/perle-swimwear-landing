    2: class MultirangeInfo(TypeInfo):
    1:     """Manage information about a multirange type."""
       
    1:     def __init__(
               self,
               name: str,
               oid: int,
               array_oid: int,
               *,
    1:         regtype: str = "",
               range_oid: int,
               subtype_oid: int,
           ):
    6:         super().__init__(name, oid, array_oid, regtype=regtype)
    6:         self.range_oid = range_oid
    6:         self.subtype_oid = subtype_oid
       
    2:     @classmethod
    2:     def _get_info_query(cls, conn: BaseConnection[Any]) -> QueryNoTemplate:
               if conn.info.server_version < 140000:
                   raise e.NotSupportedError(
                       "multirange types are only available from PostgreSQL 14"
                   )
               return sql.SQL(
                   """\
       SELECT t.typname AS name, t.oid AS oid, t.typarray AS array_oid,
           t.oid::regtype::text AS regtype,
           r.rngtypid AS range_oid, r.rngsubtype AS subtype_oid
       FROM pg_type t
       JOIN pg_range r ON t.oid = r.rngmultitypid
       WHERE t.oid = {regtype}
       """
               ).format(regtype=cls._to_regtype(conn))
       
    1:     def _added(self, registry: TypesRegistry) -> None:
               # Map multiranges ranges and subtypes to info
   12:         registry._registry[MultirangeInfo, self.range_oid] = self
   12:         registry._registry[MultirangeInfo, self.subtype_oid] = self
       
       
    2: class Multirange(MutableSequence[Range[T]]):
    1:     """Python representation for a PostgreSQL multirange type.
       
           :param items: Sequence of ranges to initialise the object.
           """
       
    1:     def __init__(self, items: Iterable[Range[T]] = ()):
               self._ranges: list[Range[T]] = list(map(self._check_type, items))
       
    1:     def _check_type(self, item: Any) -> Range[Any]:
               if not isinstance(item, Range):
                   raise TypeError(
                       f"Multirange is a sequence of Range, got {type(item).__name__}"
                   )
               return item
       
    1:     def __repr__(self) -> str:
               return f"{self.__class__.__name__}({self._ranges!r})"
       
    1:     def __str__(self) -> str:
               return f"{{{', '.join(map(str, self._ranges))}}}"
       
    2:     @overload
    2:     def __getitem__(self, index: int) -> Range[T]: ...
       
    2:     @overload
    2:     def __getitem__(self, index: slice) -> Multirange[T]: ...
       
    1:     def __getitem__(self, index: int | slice) -> Range[T] | Multirange[T]:
               if isinstance(index, int):
                   return self._ranges[index]
               else:
                   return Multirange(self._ranges[index])
       
    1:     def __len__(self) -> int:
               return len(self._ranges)
       
    2:     @overload
    2:     def __setitem__(self, index: int, value: Range[T]) -> None: ...
       
    2:     @overload
    2:     def __setitem__(self, index: slice, value: Iterable[Range[T]]) -> None: ...
       
    1:     def __setitem__(
               self, index: int | slice, value: Range[T] | Iterable[Range[T]]
           ) -> None:
               if isinstance(index, int):
                   self._check_type(value)
                   self._ranges[index] = self._check_type(value)
               elif not isinstance(value, Iterable):
                   raise TypeError("can only assign an iterable")
               else:
                   value = map(self._check_type, value)
                   self._ranges[index] = value
       
    1:     def __delitem__(self, index: int | slice) -> None:
               del self._ranges[index]
       
    1:     def insert(self, index: int, value: Range[T]) -> None:
               self._ranges.insert(index, self._check_type(value))
       
    1:     def __eq__(self, other: Any) -> bool:
               if not isinstance(other, Multirange):
                   return False
               return self._ranges == other._ranges
       
           # Order is arbitrary but consistent
       
    1:     def __lt__(self, other: Any) -> bool:
               if not isinstance(other, Multirange):
                   return NotImplemented
               return self._ranges < other._ranges
       
    1:     def __le__(self, other: Any) -> bool:
               return self == other or self < other  # type: ignore
       
    1:     def __gt__(self, other: Any) -> bool:
               if not isinstance(other, Multirange):
                   return NotImplemented
               return self._ranges > other._ranges
       
    1:     def __ge__(self, other: Any) -> bool:
               return self == other or self > other  # type: ignore
       
       
