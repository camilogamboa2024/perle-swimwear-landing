                   and args[0]):
                   args = args[0]
   10:         self.args = args
   10:         self.levelname = getLevelName(level)
   10:         self.levelno = level
   10:         self.pathname = pathname
   10:         try:
   10:             self.filename = os.path.basename(pathname)
   10:             self.module = os.path.splitext(self.filename)[0]
               except (TypeError, ValueError, AttributeError):
                   self.filename = pathname
                   self.module = "Unknown module"
   10:         self.exc_info = exc_info
   10:         self.exc_text = None      # used to cache the traceback text
   10:         self.stack_info = sinfo
   10:         self.lineno = lineno
   10:         self.funcName = func
   10:         self.created = ct
   10:         self.msecs = int((ct - int(ct)) * 1000) + 0.0  # see gh-89047
   10:         self.relativeCreated = (self.created - _startTime) * 1000
   10:         if logThreads:
   10:             self.thread = threading.get_ident()
   10:             self.threadName = threading.current_thread().name
               else: # pragma: no cover
                   self.thread = None
                   self.threadName = None
