    1: import os
    1: import pathlib
       
    1: from django.core.exceptions import SuspiciousFileOperation
       
       
    1: def validate_file_name(name, allow_relative_path=False):
           # Remove potentially dangerous names
           if os.path.basename(name) in {"", ".", ".."}:
               raise SuspiciousFileOperation("Could not derive file name from '%s'" % name)
       
           if allow_relative_path:
               # Ensure that name can be treated as a pure posix path, i.e. Unix
               # style (with forward slashes).
               path = pathlib.PurePosixPath(str(name).replace("\\", "/"))
               if path.is_absolute() or ".." in path.parts:
                   raise SuspiciousFileOperation(
                       "Detected path traversal attempt in '%s'" % name
                   )
           elif name != os.path.basename(name):
               raise SuspiciousFileOperation("File name '%s' includes path elements" % name)
       
           return name
       
       
    2: class FileProxyMixin:
    1:     """
           A mixin class used to forward file methods to an underlying file
           object.  The internal file object has to be called "file"::
       
               class FileProxy(FileProxyMixin):
                   def __init__(self, file):
                       self.file = file
           """
       
    1:     encoding = property(lambda self: self.file.encoding)
    1:     fileno = property(lambda self: self.file.fileno)
    1:     flush = property(lambda self: self.file.flush)
    1:     isatty = property(lambda self: self.file.isatty)
    1:     newlines = property(lambda self: self.file.newlines)
    1:     read = property(lambda self: self.file.read)
    1:     readinto = property(lambda self: self.file.readinto)
    1:     readline = property(lambda self: self.file.readline)
    1:     readlines = property(lambda self: self.file.readlines)
    1:     seek = property(lambda self: self.file.seek)
    1:     tell = property(lambda self: self.file.tell)
    1:     truncate = property(lambda self: self.file.truncate)
    1:     write = property(lambda self: self.file.write)
    1:     writelines = property(lambda self: self.file.writelines)
       
    2:     @property
    2:     def closed(self):
               return not self.file or self.file.closed
       
    1:     def readable(self):
               if self.closed:
                   return False
               if hasattr(self.file, "readable"):
                   return self.file.readable()
               return True
       
    1:     def writable(self):
               if self.closed:
                   return False
               if hasattr(self.file, "writable"):
                   return self.file.writable()
               return "w" in getattr(self.file, "mode", "")
       
    1:     def seekable(self):
               if self.closed:
                   return False
               if hasattr(self.file, "seekable"):
                   return self.file.seekable()
               return True
       
    1:     def __iter__(self):
               return iter(self.file)
