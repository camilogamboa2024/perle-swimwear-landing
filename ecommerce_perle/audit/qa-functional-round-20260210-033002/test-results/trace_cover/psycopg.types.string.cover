    1: """
       Adapters for textual types.
       """
       
       # Copyright (C) 2020 The Psycopg Team
       
    1: from __future__ import annotations
       
    1: from typing import TYPE_CHECKING
       
    1: from .. import _oids
    1: from ..pq import Escaping, Format
    1: from ..abc import AdaptContext
    1: from ..adapt import Buffer, Dumper, Loader
    1: from ..errors import DataError
    1: from .._encodings import conn_encoding
       
    1: if TYPE_CHECKING:
           from ..pq.abc import Escaping as EscapingProto
       
       
    2: class _BaseStrDumper(Dumper):
    1:     def __init__(self, cls: type, context: AdaptContext | None = None):
               super().__init__(cls, context)
               enc = conn_encoding(self.connection)
               self._encoding = enc if enc != "ascii" else "utf-8"
       
       
    2: class _StrBinaryDumper(_BaseStrDumper):
    1:     """
           Base class to dump a Python strings to a Postgres text type, in binary format.
       
           Subclasses shall specify the oids of real types (text, varchar, name...).
           """
       
    1:     format = Format.BINARY
       
    1:     def dump(self, obj: str) -> Buffer | None:
               # the server will raise DataError subclass if the string contains 0x00
               return obj.encode(self._encoding)
       
       
    2: class _StrDumper(_BaseStrDumper):
    1:     """
           Base class to dump a Python strings to a Postgres text type, in text format.
       
           Subclasses shall specify the oids of real types (text, varchar, name...).
           """
       
    1:     def dump(self, obj: str) -> Buffer | None:
               if "\x00" in obj:
                   raise DataError("PostgreSQL text fields cannot contain NUL (0x00) bytes")
               else:
                   return obj.encode(self._encoding)
       
       
       # The next are concrete dumpers, each one specifying the oid they dump to.
       
       
    2: class StrBinaryDumper(_StrBinaryDumper):
    1:     oid = _oids.TEXT_OID
       
       
    2: class StrBinaryDumperVarchar(_StrBinaryDumper):
    1:     oid = _oids.VARCHAR_OID
       
       
    2: class StrBinaryDumperName(_StrBinaryDumper):
    1:     oid = _oids.NAME_OID
       
       
    2: class StrDumper(_StrDumper):
    1:     """
           Dumper for strings in text format to the text oid.
       
           Note that this dumper is not used by default because the type is too strict
           and PostgreSQL would require an explicit casts to everything that is not a
           text field. However it is useful where the unknown oid is ambiguous and the
           text oid is required, for instance with variadic functions.
           """
       
    1:     oid = _oids.TEXT_OID
       
       
    2: class StrDumperVarchar(_StrDumper):
    1:     oid = _oids.VARCHAR_OID
       
       
    2: class StrDumperName(_StrDumper):
    1:     oid = _oids.NAME_OID
       
       
    2: class StrDumperUnknown(_StrDumper):
    1:     """
           Dumper for strings in text format to the unknown oid.
       
           This dumper is the default dumper for strings and allows to use Python
           strings to represent almost every data type. In a few places, however, the
           unknown oid is not accepted (for instance in variadic functions such as
           'concat()'). In that case either a cast on the placeholder ('%s::text') or
           the StrTextDumper should be used.
           """
       
    1:     pass
       
       
    2: class TextLoader(Loader):
    1:     def __init__(self, oid: int, context: AdaptContext | None = None):
               super().__init__(oid, context)
               enc = conn_encoding(self.connection)
               self._encoding = enc if enc != "ascii" else ""
       
    1:     def load(self, data: Buffer) -> bytes | str:
               if self._encoding:
                   if isinstance(data, memoryview):
                       data = bytes(data)
                   return data.decode(self._encoding)
               else:
                   # return bytes for SQL_ASCII db
                   if not isinstance(data, bytes):
                       data = bytes(data)
                   return data
       
       
    2: class TextBinaryLoader(TextLoader):
    1:     format = Format.BINARY
       
       
    2: class BytesDumper(Dumper):
    1:     oid = _oids.BYTEA_OID
    1:     _qprefix = b""
       
    1:     def __init__(self, cls: type, context: AdaptContext | None = None):
               super().__init__(cls, context)
               self._esc = Escaping(self.connection.pgconn if self.connection else None)
       
    1:     def dump(self, obj: Buffer) -> Buffer | None:
               return self._esc.escape_bytea(obj)
       
    1:     def quote(self, obj: Buffer) -> Buffer:
               if (escaped := self.dump(obj)) is None:
                   return b"NULL"
       
               # We cannot use the base quoting because escape_bytea already returns
               # the quotes content. if scs is off it will escape the backslashes in
               # the format, otherwise it won't, but it doesn't tell us what quotes to
               # use.
               if self.connection:
                   if not self._qprefix:
                       scs = self.connection.pgconn.parameter_status(
                           b"standard_conforming_strings"
                       )
                       self._qprefix = b"'" if scs == b"on" else b" E'"
       
                   return self._qprefix + escaped + b"'"
       
               # We don't have a connection, so someone is using us to generate a file
               # to use off-line or something like that. PQescapeBytea, like its
               # string counterpart, is not predictable whether it will escape
               # backslashes.
               rv: bytes = b" E'" + escaped + b"'"
               if self._esc.escape_bytea(b"\x00") == b"\\000":
                   rv = rv.replace(b"\\", b"\\\\")
               return rv
       
       
    2: class BytesBinaryDumper(Dumper):
    1:     format = Format.BINARY
    1:     oid = _oids.BYTEA_OID
       
    1:     def dump(self, obj: Buffer) -> Buffer | None:
               return obj
       
       
    2: class ByteaLoader(Loader):
    1:     _escaping: EscapingProto
       
    1:     def __init__(self, oid: int, context: AdaptContext | None = None):
               super().__init__(oid, context)
               if not hasattr(self.__class__, "_escaping"):
                   self.__class__._escaping = Escaping()
       
    1:     def load(self, data: Buffer) -> bytes:
               return self._escaping.unescape_bytea(data)
       
       
    2: class ByteaBinaryLoader(Loader):
    1:     format = Format.BINARY
       
    1:     def load(self, data: Buffer) -> Buffer:
               return data
       
       
    1: def register_default_adapters(context: AdaptContext) -> None:
    1:     adapters = context.adapters
       
           # NOTE: the order the dumpers are registered is relevant. The last one
           # registered becomes the default for each type. Usually, binary is the
           # default dumper. For text we use the text dumper as default because it
           # plays the role of unknown, and it can be cast automatically to other
           # types. However, before that, we register dumper with 'text', 'varchar',
           # 'name' oids, which will be used when a text dumper is looked up by oid.
    1:     adapters.register_dumper(str, StrBinaryDumperName)
    1:     adapters.register_dumper(str, StrBinaryDumperVarchar)
    1:     adapters.register_dumper(str, StrBinaryDumper)
    1:     adapters.register_dumper(str, StrDumperName)
    1:     adapters.register_dumper(str, StrDumperVarchar)
    1:     adapters.register_dumper(str, StrDumper)
    1:     adapters.register_dumper(str, StrDumperUnknown)
       
    1:     adapters.register_loader(_oids.INVALID_OID, TextLoader)
    1:     adapters.register_loader("bpchar", TextLoader)
    1:     adapters.register_loader("name", TextLoader)
    1:     adapters.register_loader("text", TextLoader)
    1:     adapters.register_loader("varchar", TextLoader)
    1:     adapters.register_loader('"char"', TextLoader)
    1:     adapters.register_loader("bpchar", TextBinaryLoader)
    1:     adapters.register_loader("name", TextBinaryLoader)
    1:     adapters.register_loader("text", TextBinaryLoader)
    1:     adapters.register_loader("varchar", TextBinaryLoader)
    1:     adapters.register_loader('"char"', TextBinaryLoader)
       
    1:     adapters.register_dumper(bytes, BytesDumper)
    1:     adapters.register_dumper(bytearray, BytesDumper)
    1:     adapters.register_dumper(memoryview, BytesDumper)
    1:     adapters.register_dumper(bytes, BytesBinaryDumper)
    1:     adapters.register_dumper(bytearray, BytesBinaryDumper)
    1:     adapters.register_dumper(memoryview, BytesBinaryDumper)
       
    1:     adapters.register_loader("bytea", ByteaLoader)
    1:     adapters.register_loader(_oids.INVALID_OID, ByteaBinaryLoader)
    1:     adapters.register_loader("bytea", ByteaBinaryLoader)
