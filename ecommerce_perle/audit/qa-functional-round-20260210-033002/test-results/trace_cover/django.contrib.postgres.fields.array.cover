                   try:
                       self.base_field.validate(part, model_instance)
                   except exceptions.ValidationError as error:
                       raise prefix_validation_error(
                           error,
                           prefix=self.error_messages["item_invalid"],
                           code="item_invalid",
                           params={"nth": index + 1},
