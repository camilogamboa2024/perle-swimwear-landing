    1:         PGresult = module.PGresult
    1:         Conninfo = module.Conninfo
    1:         Escaping = module.Escaping
    1:         PGcancel = module.PGcancel
    1:         PGcancelConn = module.PGcancelConn
    1:         __build_version__ = module.__build_version__
           elif impl:
