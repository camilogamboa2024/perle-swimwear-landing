                   key, value = choice
                   if isinstance(value, (list, tuple)):
                       # grouped choices (category, sub choices)
                       ret[key] = to_choices_dict(value)
                   else:
                       # paired choice (key, display value)
                       ret[key] = value
    6:     return ret
       
       
