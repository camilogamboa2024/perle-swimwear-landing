    1: import re
       
    1: from django.core import validators
    1: from django.utils.deconstruct import deconstructible
    1: from django.utils.translation import gettext_lazy as _
       
       
    3: @deconstructible
    2: class ASCIIUsernameValidator(validators.RegexValidator):
    1:     regex = r"^[\w.@+-]+\Z"
    2:     message = _(
    1:         "Enter a valid username. This value may contain only unaccented lowercase a-z "
               "and uppercase A-Z letters, numbers, and @/./+/-/_ characters."
           )
    1:     flags = re.ASCII
       
       
    3: @deconstructible
    2: class UnicodeUsernameValidator(validators.RegexValidator):
    1:     regex = r"^[\w.@+-]+\Z"
    2:     message = _(
    1:         "Enter a valid username. This value may contain only letters, "
               "numbers, and @/./+/-/_ characters."
           )
    1:     flags = 0
