    2: class PasswordChangeView(PasswordContextMixin, FormView):
    1:     form_class = PasswordChangeForm
    1:     success_url = reverse_lazy("password_change_done")
    1:     template_name = "registration/password_change_form.html"
    1:     title = _("Password change")
       
    2:     @method_decorator(sensitive_post_parameters())
    2:     @method_decorator(csrf_protect)
    2:     @method_decorator(login_required)
    2:     def dispatch(self, *args, **kwargs):
               return super().dispatch(*args, **kwargs)
       
    1:     def get_form_kwargs(self):
               kwargs = super().get_form_kwargs()
               kwargs["user"] = self.request.user
               return kwargs
       
    1:     def form_valid(self, form):
               form.save()
               # Updating the password logs out all other sessions for the user
               # except the current one.
               update_session_auth_hash(self.request, form.user)
               return super().form_valid(form)
       
       
    2: class PasswordChangeDoneView(PasswordContextMixin, TemplateView):
