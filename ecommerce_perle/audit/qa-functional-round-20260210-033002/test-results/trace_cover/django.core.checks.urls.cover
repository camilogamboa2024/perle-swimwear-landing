    2: @register(Tags.urls)
    2: def check_url_namespaces_unique(app_configs, **kwargs):
           """
           Warn if URL namespaces used in applications aren't unique.
           """
    1:     if not getattr(settings, "ROOT_URLCONF", None):
               return []
       
    1:     from django.urls import get_resolver
       
    1:     resolver = get_resolver()
    1:     all_namespaces = _load_all_namespaces(resolver)
    1:     counter = Counter(all_namespaces)
    3:     non_unique_namespaces = [n for n, count in counter.items() if count > 1]
    1:     errors = []
    1:     for namespace in non_unique_namespaces:
               errors.append(
                   Warning(
                       "URL namespace '{}' isn't unique. You may not be able to reverse "
                       "all URLs in this namespace".format(namespace),
                       id="urls.W005",
                   )
               )
    1:     return errors
       
       
    1: def _load_all_namespaces(resolver, parents=()):
           """
           Recursively load all namespaces from URL patterns.
           """
  144:     url_patterns = getattr(resolver, "url_patterns", [])
  575:     namespaces = [
    1:         ":".join(parents + (url.namespace,))
  287:         for url in url_patterns
  288:         if getattr(url, "namespace", None) is not None
           ]
  287:     for pattern in url_patterns:
  143:         namespace = getattr(pattern, "namespace", None)
  143:         current = parents
  143:         if namespace is not None:
    1:             current += (namespace,)
  143:         namespaces.extend(_load_all_namespaces(pattern, current))
  144:     return namespaces
       
       
    1: def get_warning_for_invalid_pattern(pattern):
           """
           Return a list containing a warning that the pattern is invalid.
       
           describe_pattern() cannot be used here, because we cannot rely on the
           urlpattern having regex or name attributes.
           """
           if isinstance(pattern, str):
               hint = (
                   "Try removing the string '{}'. The list of urlpatterns should not "
                   "have a prefix string as the first element.".format(pattern)
               )
           elif isinstance(pattern, tuple):
               hint = "Try using path() instead of a tuple."
           else:
               hint = None
       
           return [
               Error(
                   "Your URL pattern {!r} is invalid. Ensure that urlpatterns is a list "
                   "of path() and/or re_path() instances.".format(pattern),
                   hint=hint,
                   id="urls.E004",
               )
           ]
       
       
