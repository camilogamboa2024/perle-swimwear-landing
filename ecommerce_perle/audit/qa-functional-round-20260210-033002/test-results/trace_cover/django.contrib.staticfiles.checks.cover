    1:     id="staticfiles.E005",
       )
       
       
    1: def check_finders(app_configs=None, **kwargs):
           """Check all registered staticfiles finders."""
    1:     errors = []
    3:     for finder in get_finders():
    2:         try:
    2:             finder_errors = finder.check()
    1:         except NotImplementedError:
    1:             pass
               else:
    1:             errors.extend(finder_errors)
    1:     return errors
       
       
    1: def check_storages(app_configs=None, **kwargs):
