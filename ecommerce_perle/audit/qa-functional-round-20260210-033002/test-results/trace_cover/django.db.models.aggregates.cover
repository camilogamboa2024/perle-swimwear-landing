    2: class StdDev(NumericOutputFieldMixin, Aggregate):
    1:     name = "StdDev"
    1:     arity = 1
       
    1:     def __init__(self, expression, sample=False, **extra):
               self.function = "STDDEV_SAMP" if sample else "STDDEV_POP"
               super().__init__(expression, **extra)
       
    1:     def _get_repr_options(self):
               return {**super()._get_repr_options(), "sample": self.function == "STDDEV_SAMP"}
       
       
