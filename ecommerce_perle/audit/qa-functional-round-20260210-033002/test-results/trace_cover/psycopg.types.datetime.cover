    2: class _BaseTimeDumper(Dumper):
    1:     def get_key(self, obj: time, format: PyFormat) -> DumperKey:
               # Use (cls,) to report the need to upgrade to a dumper for timetz (the
               # Frankenstein of the data types).
               if not obj.tzinfo:
                   return self.cls
               else:
                   return (self.cls,)
       
    1:     def upgrade(self, obj: time, format: PyFormat) -> Dumper:
               raise NotImplementedError
       
    1:     def _get_offset(self, obj: time) -> timedelta:
               if (offset := obj.utcoffset()) is None:
                   raise DataError(
                       f"cannot calculate the offset of tzinfo '{obj.tzinfo}' without a date"
                   )
               return offset
       
       
