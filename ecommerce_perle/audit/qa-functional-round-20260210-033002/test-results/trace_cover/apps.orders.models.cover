    1: import uuid
    1: from django.db import models
    1: from apps.catalog.models import ProductVariant
    1: from apps.customers.models import Address, Customer
       
       
    2: class Cart(models.Model):
    1:     customer = models.ForeignKey(Customer, on_delete=models.CASCADE, null=True, blank=True)
    1:     session_key = models.CharField(max_length=50, db_index=True, blank=True)
    1:     currency = models.CharField(max_length=3, default='COP')
    1:     created_at = models.DateTimeField(auto_now_add=True)
       
       
    2: class CartItem(models.Model):
    1:     cart = models.ForeignKey(Cart, on_delete=models.CASCADE, related_name='items')
    1:     variant = models.ForeignKey(ProductVariant, on_delete=models.PROTECT)
    1:     quantity = models.PositiveIntegerField(default=1)
       
    2:     class Meta:
    1:         unique_together = ('cart', 'variant')
       
       
    2: class Coupon(models.Model):
    1:     code = models.CharField(max_length=40, unique=True)
    1:     percentage = models.PositiveSmallIntegerField(default=0)
    1:     is_active = models.BooleanField(default=True)
       
       
    2: class Order(models.Model):
    1:     PENDING = 'pending'
    1:     CONFIRMED = 'confirmed'
    1:     PAID = 'paid'
    1:     CANCELLED = 'cancelled'
    1:     STATUS_CHOICES = [(PENDING, 'Pendiente'), (CONFIRMED, 'Confirmado'), (PAID, 'Pagado'), (CANCELLED, 'Cancelado')]
    1:     PAYMENT_CHOICES = [
               ('whatsapp', 'WhatsApp'),
               ('manual', 'Manual'),
               ('wompi', 'Wompi'),
               ('stripe', 'Stripe'),
           ]
       
    1:     public_id = models.UUIDField(default=uuid.uuid4, unique=True, editable=False, db_index=True)
    1:     session_key = models.CharField(max_length=50, blank=True, db_index=True)
    1:     customer = models.ForeignKey(Customer, on_delete=models.PROTECT)
    1:     address = models.ForeignKey(Address, on_delete=models.PROTECT)
    1:     coupon = models.ForeignKey(Coupon, on_delete=models.SET_NULL, null=True, blank=True)
    1:     status = models.CharField(max_length=20, choices=STATUS_CHOICES, default=PENDING, db_index=True)
    1:     payment_method = models.CharField(max_length=20, choices=PAYMENT_CHOICES, default='whatsapp')
    1:     whatsapp_message = models.TextField(blank=True)
    1:     subtotal = models.PositiveIntegerField(default=0)
    1:     discount_total = models.PositiveIntegerField(default=0)
    1:     grand_total = models.PositiveIntegerField(default=0)
    1:     currency = models.CharField(max_length=3, default='COP')
    1:     paid_at = models.DateTimeField(null=True, blank=True)
    1:     created_at = models.DateTimeField(auto_now_add=True, db_index=True)
       
    2:     class Meta:
    1:         indexes = [models.Index(fields=['status', 'created_at'])]
       
       
    2: class OrderItem(models.Model):
    1:     order = models.ForeignKey(Order, on_delete=models.CASCADE, related_name='items')
    1:     variant = models.ForeignKey(ProductVariant, on_delete=models.PROTECT)
    1:     quantity = models.PositiveIntegerField()
    1:     unit_price = models.PositiveIntegerField()
    1:     line_total = models.PositiveIntegerField()
       
       
    2: class OrderStatusHistory(models.Model):
    1:     order = models.ForeignKey(Order, on_delete=models.CASCADE, related_name='status_history')
    1:     from_status = models.CharField(max_length=20, blank=True)
    1:     to_status = models.CharField(max_length=20)
    1:     changed_at = models.DateTimeField(auto_now_add=True)
