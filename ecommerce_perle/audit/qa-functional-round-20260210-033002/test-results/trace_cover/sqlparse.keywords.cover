    1: from sqlparse import tokens
       
       # object() only supports "is" and is useful as a marker
       # use this marker to specify that the given regex in SQL_REGEX
       # shall be processed further through a lookup in the KEYWORDS dictionaries
    1: PROCESS_AS_KEYWORD = object()
       
       
   54: SQL_REGEX = [
    1:     (r'(--|# )\+.*?(\r\n|\r|\n|$)', tokens.Comment.Single.Hint),
    1:     (r'/\*\+[\s\S]*?\*/', tokens.Comment.Multiline.Hint),
       
    1:     (r'(--|# ).*?(\r\n|\r|\n|$)', tokens.Comment.Single),
    1:     (r'/\*[\s\S]*?\*/', tokens.Comment.Multiline),
       
    1:     (r'(\r\n|\r|\n)', tokens.Newline),
    1:     (r'\s+?', tokens.Whitespace),
       
    1:     (r':=', tokens.Assignment),
    1:     (r'::', tokens.Punctuation),
       
    1:     (r'\*', tokens.Wildcard),
       
    1:     (r"`(``|[^`])*`", tokens.Name),
    1:     (r"´(´´|[^´])*´", tokens.Name),
    1:     (r'((?<![\w\"\$])\$(?:[_A-ZÀ-Ü]\w*)?\$)[\s\S]*?\1', tokens.Literal),
       
    1:     (r'\?', tokens.Name.Placeholder),
    1:     (r'%(\(\w+\))?s', tokens.Name.Placeholder),
    1:     (r'(?<!\w)[$:?]\w+', tokens.Name.Placeholder),
       
    1:     (r'\\\w+', tokens.Command),
       
           # FIXME(andi): VALUES shouldn't be listed here
           # see https://github.com/andialbrecht/sqlparse/pull/64
           # AS and IN are special, it may be followed by a parenthesis, but
           # are never functions, see issue183 and issue507
    1:     (r'(CASE|IN|VALUES|USING|FROM|AS)\b', tokens.Keyword),
       
    1:     (r'(@|##|#)[A-ZÀ-Ü]\w+', tokens.Name),
       
           # see issue #39
           # Spaces around period `schema . name` are valid identifier
           # TODO: Spaces before period not implemented
    1:     (r'[A-ZÀ-Ü]\w*(?=\s*\.)', tokens.Name),  # 'Name'.
           # FIXME(atronah): never match,
           # because `re.match` doesn't work with look-behind regexp feature
    1:     (r'(?<=\.)[A-ZÀ-Ü]\w*', tokens.Name),  # .'Name'
    1:     (r'[A-ZÀ-Ü]\w*(?=\()', tokens.Name),  # side effect: change kw to func
    1:     (r'-?0x[\dA-F]+', tokens.Number.Hexadecimal),
    1:     (r'-?\d+(\.\d+)?E-?\d+', tokens.Number.Float),
    2:     (r'(?![_A-ZÀ-Ü])-?(\d+(\.\d*)|\.\d+)(?![_A-ZÀ-Ü])',
    1:      tokens.Number.Float),
    1:     (r'(?![_A-ZÀ-Ü])-?\d+(?![_A-ZÀ-Ü])', tokens.Number.Integer),
    1:     (r"'(''|\\'|[^'])*'", tokens.String.Single),
           # not a real string literal in ANSI SQL:
    1:     (r'"(""|\\"|[^"])*"', tokens.String.Symbol),
    1:     (r'(""|".*?[^\\]")', tokens.String.Symbol),
           # sqlite names can be escaped with [square brackets]. left bracket
           # cannot be preceded by word character or a right bracket --
           # otherwise it's probably an array index
    1:     (r'(?<![\w\])])(\[[^\]\[]+\])', tokens.Name),
    2:     (r'((LEFT\s+|RIGHT\s+|FULL\s+)?(INNER\s+|OUTER\s+|STRAIGHT\s+)?'
    1:      r'|(CROSS\s+|NATURAL\s+)?)?JOIN\b', tokens.Keyword),
    1:     (r'END(\s+IF|\s+LOOP|\s+WHILE)?\b', tokens.Keyword),
    1:     (r'IF\s+(NOT\s+)?EXISTS\b', tokens.Keyword),
    1:     (r'NOT\s+NULL\b', tokens.Keyword),
    1:     (r'(ASC|DESC)(\s+NULLS\s+(FIRST|LAST))?\b', tokens.Keyword.Order),
    1:     (r'(ASC|DESC)\b', tokens.Keyword.Order),
    1:     (r'NULLS\s+(FIRST|LAST)\b', tokens.Keyword.Order),
    1:     (r'UNION\s+ALL\b', tokens.Keyword),
    1:     (r'CREATE(\s+OR\s+REPLACE)?\b', tokens.Keyword.DDL),
    1:     (r'DOUBLE\s+PRECISION\b', tokens.Name.Builtin),
    1:     (r'GROUP\s+BY\b', tokens.Keyword),
    1:     (r'ORDER\s+BY\b', tokens.Keyword),
    1:     (r'PRIMARY\s+KEY\b', tokens.Keyword),
    1:     (r'HANDLER\s+FOR\b', tokens.Keyword),
    1:     (r'GO(\s\d+)\b', tokens.Keyword),
    2:     (r'(LATERAL\s+VIEW\s+)'
            r'(EXPLODE|INLINE|PARSE_URL_TUPLE|POSEXPLODE|STACK)\b',
    1:      tokens.Keyword),
    1:     (r"(AT|WITH')\s+TIME\s+ZONE\s+'[^']+'", tokens.Keyword.TZCast),
    1:     (r'(NOT\s+)?(LIKE|ILIKE|RLIKE)\b', tokens.Operator.Comparison),
    1:     (r'(NOT\s+)?(REGEXP)(\s+(BINARY))?\b', tokens.Operator.Comparison),
           # Check for keywords, also returns tokens.Name if regex matches
           # but the match isn't a keyword.
    1:     (r'\w[$#\w]*', PROCESS_AS_KEYWORD),
    1:     (r'[;:()\[\],\.]', tokens.Punctuation),
           # JSON operators
    1:     (r'(\->>?|#>>?|@>|<@|\?\|?|\?&|\-|#\-)', tokens.Operator),
    1:     (r'[<>=~!]+', tokens.Operator.Comparison),
    1:     (r'[+/@#%^&|^-]+', tokens.Operator),
       ]
       
