    1: from django.apps import AppConfig
    1: from django.contrib.messages.storage import base
    1: from django.contrib.messages.utils import get_level_tags
    1: from django.core.signals import setting_changed
    1: from django.utils.functional import SimpleLazyObject
    1: from django.utils.translation import gettext_lazy as _
       
       
    1: def update_level_tags(setting, **kwargs):
    4:     if setting == "MESSAGE_TAGS":
               base.LEVEL_TAGS = SimpleLazyObject(get_level_tags)
       
       
    2: class MessagesConfig(AppConfig):
    1:     name = "django.contrib.messages"
    1:     verbose_name = _("Messages")
       
    1:     def ready(self):
    1:         setting_changed.connect(update_level_tags)
