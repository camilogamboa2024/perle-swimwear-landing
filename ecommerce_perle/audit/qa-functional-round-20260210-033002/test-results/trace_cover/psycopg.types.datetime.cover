               (\d+|[a-z]+)    [^a-z0-9]               # Month or day
               (\d+) [^a-z0-9] (\d+) [^a-z0-9] (\d+)   # Time
               (?: \.(\d+) )?                          # Micros
               [^a-z0-9] (\d+)                         # Year
               $
               """
           )
       
    1:     _ORDER_YMD = 0
    1:     _ORDER_DMY = 1
    1:     _ORDER_MDY = 2
    1:     _ORDER_PGDM = 3
    1:     _ORDER_PGMD = 4
       
    1:     def __init__(self, oid: int, context: AdaptContext | None = None):
               super().__init__(oid, context)
