    1: def _parse_row_binary(data: Buffer, tx: Transformer) -> tuple[Any, ...]:
           row: list[Buffer | None] = []
           nfields = _unpack_int2(data, 0)[0]
           pos = 2
           for i in range(nfields):
               length = _unpack_int4(data, pos)[0]
               pos += 4
               if length >= 0:
                   row.append(data[pos : pos + length])
                   pos += length
               else:
