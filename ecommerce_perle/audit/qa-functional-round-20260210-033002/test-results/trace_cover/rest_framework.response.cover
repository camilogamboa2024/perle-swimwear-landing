   23:         self['Content-Type'] = content_type
       
   23:         ret = renderer.render(self.data, accepted_media_type, context)
   23:         if isinstance(ret, str):
                   assert charset, (
                       'renderer returned unicode, and did not specify '
                       'a charset value.'
                   )
                   return ret.encode(charset)
       
   23:         if not ret:
                   del self['Content-Type']
       
   23:         return ret
       
    2:     @property
    2:     def status_text(self):
