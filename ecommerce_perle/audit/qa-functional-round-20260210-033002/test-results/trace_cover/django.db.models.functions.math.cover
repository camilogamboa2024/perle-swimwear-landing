    2: class Random(NumericOutputFieldMixin, Func):
    1:     function = "RANDOM"
    1:     arity = 0
       
    1:     def as_mysql(self, compiler, connection, **extra_context):
               return super().as_sql(compiler, connection, function="RAND", **extra_context)
       
    1:     def as_oracle(self, compiler, connection, **extra_context):
               return super().as_sql(
                   compiler, connection, function="DBMS_RANDOM.VALUE", **extra_context
               )
       
    1:     def as_sqlite(self, compiler, connection, **extra_context):
               return super().as_sql(compiler, connection, function="RAND", **extra_context)
       
    1:     def get_group_by_cols(self):
               return []
       
       
    2: class Round(FixDecimalInputMixin, Transform):
    1:     function = "ROUND"
    1:     lookup_name = "round"
    1:     arity = None  # Override Transform's arity=1 to enable passing precision.
       
    1:     def __init__(self, expression, precision=0, **extra):
               super().__init__(expression, precision, **extra)
       
    1:     def as_sqlite(self, compiler, connection, **extra_context):
               precision = self.get_source_expressions()[1]
               if isinstance(precision, Value) and precision.value < 0:
                   raise ValueError("SQLite does not support negative precision.")
               return super().as_sqlite(compiler, connection, **extra_context)
       
    1:     def _resolve_output_field(self):
               source = self.get_source_expressions()[0]
               return source.output_field
       
       
