    2:         "max_decimal_places": ngettext_lazy(
    1:             "Ensure that there are no more than %(max)s decimal place.",
    1:             "Ensure that there are no more than %(max)s decimal places.",
    1:             "max",
               ),
    2:         "max_whole_digits": ngettext_lazy(
    1:             "Ensure that there are no more than %(max)s digit before the decimal "
                   "point.",
    1:             "Ensure that there are no more than %(max)s digits before the decimal "
                   "point.",
    1:             "max",
