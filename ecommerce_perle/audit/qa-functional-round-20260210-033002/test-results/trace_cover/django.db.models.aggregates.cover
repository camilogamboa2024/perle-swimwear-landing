    1:     def _get_repr_options(self):
               options = super()._get_repr_options()
               if self.distinct:
                   options["distinct"] = self.distinct
               if self.filter:
                   options["filter"] = self.filter
               return options
       
       
    2: class Avg(FixDurationInputMixin, NumericOutputFieldMixin, Aggregate):
    1:     function = "AVG"
    1:     name = "Avg"
    1:     allow_distinct = True
