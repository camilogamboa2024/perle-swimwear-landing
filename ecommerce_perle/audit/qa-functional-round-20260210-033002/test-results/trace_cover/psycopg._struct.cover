    1: """
       Utility functions to deal with binary structs.
       """
       
       # Copyright (C) 2020 The Psycopg Team
       
    1: from __future__ import annotations
       
    1: import struct
    1: from typing import Protocol, TypeAlias, cast
    1: from collections.abc import Callable
       
    1: from . import errors as e
    1: from .abc import Buffer
       
    1: PackInt: TypeAlias = Callable[[int], bytes]
    1: UnpackInt: TypeAlias = Callable[[Buffer], tuple[int]]
    1: PackFloat: TypeAlias = Callable[[float], bytes]
    1: UnpackFloat: TypeAlias = Callable[[Buffer], tuple[float]]
       
       
    2: class UnpackLen(Protocol):
    1:     def __call__(self, data: Buffer, start: int | None) -> tuple[int]: ...
       
       
    1: pack_int2 = cast(PackInt, struct.Struct("!h").pack)
    1: pack_uint2 = cast(PackInt, struct.Struct("!H").pack)
    1: pack_int4 = cast(PackInt, struct.Struct("!i").pack)
    1: pack_uint4 = cast(PackInt, struct.Struct("!I").pack)
    1: pack_int8 = cast(PackInt, struct.Struct("!q").pack)
    1: pack_float4 = cast(PackFloat, struct.Struct("!f").pack)
    1: pack_float8 = cast(PackFloat, struct.Struct("!d").pack)
       
    1: unpack_int2 = cast(UnpackInt, struct.Struct("!h").unpack)
    1: unpack_uint2 = cast(UnpackInt, struct.Struct("!H").unpack)
    1: unpack_int4 = cast(UnpackInt, struct.Struct("!i").unpack)
    1: unpack_uint4 = cast(UnpackInt, struct.Struct("!I").unpack)
    1: unpack_int8 = cast(UnpackInt, struct.Struct("!q").unpack)
    1: unpack_float4 = cast(UnpackFloat, struct.Struct("!f").unpack)
    1: unpack_float8 = cast(UnpackFloat, struct.Struct("!d").unpack)
       
    1: _struct_len = struct.Struct("!i")
    1: pack_len = cast(Callable[[int], bytes], _struct_len.pack)
    1: unpack_len = cast(UnpackLen, _struct_len.unpack_from)
       
       
    1: def pack_float4_bug_304(x: float) -> bytes:
           raise e.InterfaceError(
               "cannot dump Float4: Python affected by bug #304. Note that the psycopg-c"
               " and psycopg-binary packages are not affected by this issue."
               " See https://github.com/psycopg/psycopg/issues/304"
           )
       
       
       # If issue #304 is detected, raise an error instead of dumping wrong data.
    1: if struct.Struct("!f").pack(1.0) != bytes.fromhex("3f800000"):
           pack_float4 = pack_float4_bug_304
