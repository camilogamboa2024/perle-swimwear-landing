    1:     def insert_before(self, where, token):
               """Inserts *token* before *where*."""
               if not isinstance(where, int):
                   where = self.token_index(where)
               token.parent = self
               self.tokens.insert(where, token)
       
    1:     def insert_after(self, where, token, skip_ws=True):
               """Inserts *token* after *where*."""
               if not isinstance(where, int):
                   where = self.token_index(where)
               nidx, next_ = self.token_next(where, skip_ws=skip_ws)
               token.parent = self
               if next_ is None:
                   self.tokens.append(token)
               else:
                   self.tokens.insert(nidx, token)
       
