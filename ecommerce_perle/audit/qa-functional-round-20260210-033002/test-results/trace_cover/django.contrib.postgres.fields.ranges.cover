    2: class RangeBoundary(models.Expression):
    1:     """A class that represents range boundaries."""
       
    1:     def __init__(self, inclusive_lower=True, inclusive_upper=False):
               self.lower = "[" if inclusive_lower else "("
               self.upper = "]" if inclusive_upper else ")"
       
    1:     def as_sql(self, compiler, connection):
               return "'%s%s'" % (self.lower, self.upper), []
       
       
    2: class RangeOperators:
           # https://www.postgresql.org/docs/current/functions-range.html#RANGE-OPERATORS-TABLE
    1:     EQUAL = "="
    1:     NOT_EQUAL = "<>"
    1:     CONTAINS = "@>"
    1:     CONTAINED_BY = "<@"
    1:     OVERLAPS = "&&"
    1:     FULLY_LT = "<<"
    1:     FULLY_GT = ">>"
    1:     NOT_LT = "&>"
    1:     NOT_GT = "&<"
    1:     ADJACENT_TO = "-|-"
       
       
    2: class RangeField(models.Field):
    1:     empty_strings_allowed = False
       
    1:     def __init__(self, *args, **kwargs):
               if "default_bounds" in kwargs:
                   raise TypeError(
                       f"Cannot use 'default_bounds' with {self.__class__.__name__}."
                   )
               # Initializing base_field here ensures that its model matches the model
               # for self.
               if hasattr(self, "base_field"):
                   self.base_field = self.base_field()
               super().__init__(*args, **kwargs)
       
    2:     @property
    2:     def model(self):
               try:
                   return self.__dict__["model"]
               except KeyError:
                   raise AttributeError(
                       "'%s' object has no attribute 'model'" % self.__class__.__name__
                   )
       
    2:     @model.setter
    2:     def model(self, model):
               self.__dict__["model"] = model
               self.base_field.model = model
       
    2:     @classmethod
    2:     def _choices_is_value(cls, value):
               return isinstance(value, (list, tuple)) or super()._choices_is_value(value)
       
    1:     def get_placeholder(self, value, compiler, connection):
               return "%s::{}".format(self.db_type(connection))
       
    1:     def get_prep_value(self, value):
               if value is None:
                   return None
               elif isinstance(value, Range):
                   return value
               elif isinstance(value, (list, tuple)):
                   return self.range_type(value[0], value[1])
               return value
       
    1:     def to_python(self, value):
               if isinstance(value, str):
                   # Assume we're deserializing
                   vals = json.loads(value)
                   for end in ("lower", "upper"):
                       if end in vals:
                           vals[end] = self.base_field.to_python(vals[end])
                   value = self.range_type(**vals)
               elif isinstance(value, (list, tuple)):
                   value = self.range_type(value[0], value[1])
               return value
       
    1:     def set_attributes_from_name(self, name):
               super().set_attributes_from_name(name)
               self.base_field.set_attributes_from_name(name)
       
    1:     def value_to_string(self, obj):
               value = self.value_from_object(obj)
               if value is None:
                   return None
               if value.isempty:
                   return json.dumps({"empty": True})
               base_field = self.base_field
               result = {"bounds": value._bounds}
               for end in ("lower", "upper"):
                   val = getattr(value, end)
                   if val is None:
                       result[end] = None
                   else:
                       obj = AttributeSetter(base_field.attname, val)
                       result[end] = base_field.value_to_string(obj)
               return json.dumps(result)
       
    1:     def formfield(self, **kwargs):
               kwargs.setdefault("form_class", self.form_field)
               return super().formfield(**kwargs)
       
       
    1: CANONICAL_RANGE_BOUNDS = "[)"
       
       
    2: class ContinuousRangeField(RangeField):
    1:     """
           Continuous range field. It allows specifying default bounds for list and
           tuple inputs.
           """
       
    1:     def __init__(self, *args, default_bounds=CANONICAL_RANGE_BOUNDS, **kwargs):
               if default_bounds not in ("[)", "(]", "()", "[]"):
                   raise ValueError("default_bounds must be one of '[)', '(]', '()', or '[]'.")
               self.default_bounds = default_bounds
               super().__init__(*args, **kwargs)
       
    1:     def get_prep_value(self, value):
               if isinstance(value, (list, tuple)):
                   return self.range_type(value[0], value[1], self.default_bounds)
               return super().get_prep_value(value)
       
    1:     def formfield(self, **kwargs):
               kwargs.setdefault("default_bounds", self.default_bounds)
               return super().formfield(**kwargs)
       
    1:     def deconstruct(self):
               name, path, args, kwargs = super().deconstruct()
               if self.default_bounds and self.default_bounds != CANONICAL_RANGE_BOUNDS:
                   kwargs["default_bounds"] = self.default_bounds
               return name, path, args, kwargs
       
       
