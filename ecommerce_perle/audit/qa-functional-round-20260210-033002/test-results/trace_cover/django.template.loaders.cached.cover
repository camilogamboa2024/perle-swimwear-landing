    1: """
       Wrapper class that takes a list of template loaders as an argument and attempts
       to load templates from them in order, caching the result.
       """
       
    1: import hashlib
       
    1: from django.template import TemplateDoesNotExist
    1: from django.template.backends.django import copy_exception
       
    1: from .base import Loader as BaseLoader
       
       
    2: class Loader(BaseLoader):
    1:     def __init__(self, engine, loaders):
    1:         self.get_template_cache = {}
    1:         self.loaders = engine.get_template_loaders(loaders)
    1:         super().__init__(engine)
       
    1:     def get_dirs(self):
               for loader in self.loaders:
                   if hasattr(loader, "get_dirs"):
                       yield from loader.get_dirs()
       
    1:     def get_contents(self, origin):
    5:         return origin.loader.get_contents(origin)
       
    1:     def get_template(self, template_name, skip=None):
               """
               Perform the caching that gives this loader its name. Often many of the
               templates attempted will be missing, so memory use is of concern here.
               To keep it in check, caching behavior is a little complicated when a
               template is not found. See ticket #26306 for more details.
       
               With template debugging disabled, cache the TemplateDoesNotExist class
               for every missing template and raise a new instance of it after
               fetching it from the cache.
       
               With template debugging enabled, a unique TemplateDoesNotExist object
               is cached for each missing template to preserve debug data. When
               raising an exception, Python sets __traceback__, __context__, and
               __cause__ attributes on it. Those attributes can contain references to
               all sorts of objects up the call chain and caching them creates a
               memory leak. Thus, unraised copies of the exceptions are cached and
               copies of those copies are raised after they're fetched from the cache.
               """
   40:         key = self.cache_key(template_name, skip)
   40:         cached = self.get_template_cache.get(key)
   40:         if cached:
   35:             if isinstance(cached, type) and issubclass(cached, TemplateDoesNotExist):
                       raise cached(template_name)
   35:             elif isinstance(cached, TemplateDoesNotExist):
                       raise copy_exception(cached)
   35:             return cached
       
    5:         try:
    5:             template = super().get_template(template_name, skip)
               except TemplateDoesNotExist as e:
                   self.get_template_cache[key] = (
                       copy_exception(e) if self.engine.debug else TemplateDoesNotExist
                   )
                   raise
               else:
    5:             self.get_template_cache[key] = template
       
    5:         return template
       
    1:     def get_template_sources(self, template_name):
    5:         for loader in self.loaders:
    5:             yield from loader.get_template_sources(template_name)
       
    1:     def cache_key(self, template_name, skip=None):
               """
               Generate a cache key for the template name and skip.
       
               If skip is provided, only origins that match template_name are included
               in the cache key. This ensures each template is only parsed and cached
               once if contained in different extend chains like:
       
                   x -> a -> a
                   y -> a -> a
                   z -> a -> a
               """
   40:         skip_prefix = ""
       
   40:         if skip:
   80:             matching = [
   60:                 origin.name for origin in skip if origin.template_name == template_name
                   ]
   20:             if matching:
                       skip_prefix = self.generate_hash(matching)
       
  160:         return "-".join(s for s in (str(template_name), skip_prefix) if s)
       
    1:     def generate_hash(self, values):
               return hashlib.sha1("|".join(values).encode()).hexdigest()
       
    1:     def reset(self):
               "Empty the template cache."
               self.get_template_cache.clear()
