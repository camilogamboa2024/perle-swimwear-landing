    2: class TimeBinaryDumper(_BaseTimeDumper):
    1:     format = Format.BINARY
    1:     oid = _oids.TIME_OID
       
    1:     def dump(self, obj: time) -> Buffer | None:
               us = obj.microsecond + 1_000_000 * (
                   obj.second + 60 * (obj.minute + 60 * obj.hour)
               )
               return pack_int8(us)
       
    1:     def upgrade(self, obj: time, format: PyFormat) -> Dumper:
               if not obj.tzinfo:
