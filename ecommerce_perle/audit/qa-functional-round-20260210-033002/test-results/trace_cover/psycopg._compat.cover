    1: """
       compatibility functions for different Python versions
       """
       
       # Copyright (C) 2021 The Psycopg Team
       
    1: from __future__ import annotations
       
    1: import sys
    1: from typing import Any, Iterator
       
    1: if sys.version_info >= (3, 11):
    1:     from typing import LiteralString, Self
       else:
           from typing_extensions import LiteralString, Self
       
    1: if sys.version_info >= (3, 12):
           _asyncio_run_snippet = (
               "running 'asyncio.run(...,"
               " loop_factory=asyncio.SelectorEventLoop(selectors.SelectSelector()))'"
           )
       
       else:
    1:     _asyncio_run_snippet = (
    1:         "setting 'asyncio.set_event_loop_policy(WindowsSelectorEventLoopPolicy())'"
           )
       
    1: if sys.version_info >= (3, 13):
           from typing import TypeVar
       else:
    1:     from typing_extensions import TypeVar
       
    1: if sys.version_info >= (3, 14):
           from string.templatelib import Interpolation, Template
       else:
    1:     from dataclasses import dataclass
       
    2:     class Template:
    1:         strings: tuple[str]
    1:         interpolations: tuple[Interpolation]
       
    1:         def __new__(cls, *args: str | Interpolation) -> Self:
                   return cls()
       
    1:         def __iter__(self) -> Iterator[str | Interpolation]:
                   return
                   yield
       
    3:     @dataclass
    2:     class Interpolation:
    1:         value: Any
    1:         expression: str
    1:         conversion: str | None
    1:         format_spec: str
       
       
    1: __all__ = [
           "Interpolation",
           "LiteralString",
           "Self",
           "Template",
           "TypeVar",
       ]
