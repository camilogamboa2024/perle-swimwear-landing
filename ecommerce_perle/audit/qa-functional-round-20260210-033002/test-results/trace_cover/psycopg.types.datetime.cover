    1: def _get_datestyle(conn: BaseConnection[Any] | None) -> bytes:
           if conn and (ds := conn.pgconn.parameter_status(b"DateStyle")):
               return ds
       
           return b"ISO, DMY"
       
       
    1: def _get_intervalstyle(conn: BaseConnection[Any] | None) -> bytes:
