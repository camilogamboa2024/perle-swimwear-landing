    2: class ContentType(models.Model):
    1:     app_label = models.CharField(max_length=100)
    1:     model = models.CharField(_("python model class name"), max_length=100)
    1:     objects = ContentTypeManager()
       
    2:     class Meta:
    1:         verbose_name = _("content type")
    1:         verbose_name_plural = _("content types")
    1:         db_table = "django_content_type"
    1:         unique_together = [["app_label", "model"]]
       
    1:     def __str__(self):
               return self.app_labeled_name
       
    2:     @property
    2:     def name(self):
               model = self.model_class()
               if not model:
                   return self.model
               return str(model._meta.verbose_name)
       
    2:     @property
    2:     def app_labeled_name(self):
               model = self.model_class()
               if not model:
                   return self.model
               return "%s | %s" % (
                   model._meta.app_config.verbose_name,
                   model._meta.verbose_name,
               )
       
    1:     def model_class(self):
               """Return the model class for this type of content."""
               try:
                   return apps.get_model(self.app_label, self.model)
               except LookupError:
                   return None
       
    1:     def get_object_for_this_type(self, using=None, **kwargs):
               """
               Return an object of this type for the keyword arguments given.
               Basically, this is a proxy around this object_type's get_object() model
               method. The ObjectNotExist exception, if thrown, will not be caught,
               so code that calls this method should catch it.
               """
               return self.model_class()._base_manager.using(using).get(**kwargs)
       
    1:     def get_all_objects_for_this_type(self, **kwargs):
               """
               Return all objects of this type for the keyword arguments given.
               """
               return self.model_class()._base_manager.filter(**kwargs)
       
    1:     def natural_key(self):
               return (self.app_label, self.model)
