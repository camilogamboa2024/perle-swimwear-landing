    1: import os
    1: import time
    1: import warnings
       
    1: from asgiref.local import Local
       
    1: from django.apps import apps
    1: from django.core.exceptions import ImproperlyConfigured
    1: from django.core.signals import setting_changed
    1: from django.db import connections, router
    1: from django.db.utils import ConnectionRouter
    1: from django.dispatch import Signal, receiver
    1: from django.utils import timezone
    1: from django.utils.formats import FORMAT_SETTINGS, reset_format_cache
    1: from django.utils.functional import empty
       
    1: template_rendered = Signal()
       
       # Most setting_changed receivers are supposed to be added below,
       # except for cases where the receiver is related to a contrib app.
       
       # Settings that may not work well when using 'override_settings' (#19031)
    1: COMPLEX_OVERRIDE_SETTINGS = {"DATABASES"}
       
       
    2: @receiver(setting_changed)
    2: def clear_cache_handlers(*, setting, **kwargs):
    4:     if setting == "CACHES":
               from django.core.cache import caches, close_caches
       
               close_caches()
               caches._settings = caches.settings = caches.configure_settings(None)
               caches._connections = Local()
       
       
    2: @receiver(setting_changed)
    2: def update_installed_apps(*, setting, **kwargs):
    4:     if setting == "INSTALLED_APPS":
               # Rebuild any AppDirectoriesFinder instance.
               from django.contrib.staticfiles.finders import get_finder
       
               get_finder.cache_clear()
               # Rebuild management commands cache
               from django.core.management import get_commands
       
               get_commands.cache_clear()
               # Rebuild get_app_template_dirs cache.
               from django.template.utils import get_app_template_dirs
       
               get_app_template_dirs.cache_clear()
               # Rebuild translations cache.
               from django.utils.translation import trans_real
       
               trans_real._translations = {}
       
       
    2: @receiver(setting_changed)
    2: def update_connections_time_zone(*, setting, **kwargs):
    4:     if setting == "TIME_ZONE":
               # Reset process time zone
               if hasattr(time, "tzset"):
                   if kwargs["value"]:
                       os.environ["TZ"] = kwargs["value"]
                   else:
                       os.environ.pop("TZ", None)
                   time.tzset()
       
               # Reset local time zone cache
               timezone.get_default_timezone.cache_clear()
       
           # Reset the database connections' time zone
    4:     if setting in {"TIME_ZONE", "USE_TZ"}:
               for conn in connections.all(initialized_only=True):
                   try:
                       del conn.timezone
                   except AttributeError:
                       pass
                   try:
                       del conn.timezone_name
                   except AttributeError:
                       pass
                   conn.ensure_timezone()
       
       
    2: @receiver(setting_changed)
    2: def clear_routers_cache(*, setting, **kwargs):
    4:     if setting == "DATABASE_ROUTERS":
               router.routers = ConnectionRouter().routers
       
       
    2: @receiver(setting_changed)
    2: def reset_template_engines(*, setting, **kwargs):
    4:     if setting in {
               "TEMPLATES",
               "DEBUG",
               "INSTALLED_APPS",
           }:
               from django.template import engines
       
               try:
                   del engines.templates
               except AttributeError:
                   pass
               engines._templates = None
               engines._engines = {}
               from django.template.engine import Engine
       
               Engine.get_default.cache_clear()
               from django.forms.renderers import get_default_renderer
       
               get_default_renderer.cache_clear()
       
       
    2: @receiver(setting_changed)
    2: def storages_changed(*, setting, **kwargs):
    4:     from django.contrib.staticfiles.storage import staticfiles_storage
    4:     from django.core.files.storage import default_storage, storages
       
    4:     if setting in (
               "STORAGES",
               "STATIC_ROOT",
               "STATIC_URL",
           ):
               try:
                   del storages.backends
               except AttributeError:
                   pass
               storages._backends = None
               storages._storages = {}
       
               default_storage._wrapped = empty
               staticfiles_storage._wrapped = empty
       
       
    2: @receiver(setting_changed)
    2: def clear_serializers_cache(*, setting, **kwargs):
    4:     if setting == "SERIALIZATION_MODULES":
               from django.core import serializers
       
               serializers._serializers = {}
       
       
    2: @receiver(setting_changed)
    2: def language_changed(*, setting, **kwargs):
    4:     if setting in {"LANGUAGES", "LANGUAGE_CODE", "LOCALE_PATHS"}:
               from django.utils.translation import trans_real
       
               trans_real._default = None
               trans_real._active = Local()
    4:     if setting in {"LANGUAGES", "LOCALE_PATHS"}:
               from django.utils.translation import trans_real
       
               trans_real._translations = {}
               trans_real.check_for_language.cache_clear()
       
       
    2: @receiver(setting_changed)
    2: def localize_settings_changed(*, setting, **kwargs):
    4:     if setting in FORMAT_SETTINGS or setting == "USE_THOUSAND_SEPARATOR":
               reset_format_cache()
       
       
    2: @receiver(setting_changed)
    2: def complex_setting_changed(*, enter, setting, **kwargs):
    4:     if enter and setting in COMPLEX_OVERRIDE_SETTINGS:
               # Considering the current implementation of the signals framework,
               # this stacklevel shows the line containing the override_settings call.
               warnings.warn(
                   f"Overriding setting {setting} can lead to unexpected behavior.",
                   stacklevel=5,
               )
       
       
    2: @receiver(setting_changed)
    2: def root_urlconf_changed(*, setting, **kwargs):
    4:     if setting == "ROOT_URLCONF":
               from django.urls import clear_url_caches, set_urlconf
       
               clear_url_caches()
               set_urlconf(None)
       
       
    2: @receiver(setting_changed)
    2: def static_storage_changed(*, setting, **kwargs):
    4:     if setting in {
               "STATIC_ROOT",
               "STATIC_URL",
           }:
               from django.contrib.staticfiles.storage import staticfiles_storage
       
               staticfiles_storage._wrapped = empty
       
       
    2: @receiver(setting_changed)
    2: def static_finders_changed(*, setting, **kwargs):
    4:     if setting in {
               "STATICFILES_DIRS",
               "STATIC_ROOT",
           }:
               from django.contrib.staticfiles.finders import get_finder
       
               get_finder.cache_clear()
       
       
    2: @receiver(setting_changed)
    2: def form_renderer_changed(*, setting, **kwargs):
    4:     if setting == "FORM_RENDERER":
               from django.forms.renderers import get_default_renderer
       
               get_default_renderer.cache_clear()
       
       
    2: @receiver(setting_changed)
    2: def auth_password_validators_changed(*, setting, **kwargs):
    4:     if setting == "AUTH_PASSWORD_VALIDATORS":
               from django.contrib.auth.password_validation import (
                   get_default_password_validators,
               )
       
               get_default_password_validators.cache_clear()
       
       
    2: @receiver(setting_changed)
    2: def user_model_swapped(*, setting, **kwargs):
    4:     if setting == "AUTH_USER_MODEL":
               apps.clear_cache()
               try:
                   from django.contrib.auth import get_user_model
       
                   UserModel = get_user_model()
               except ImproperlyConfigured:
                   # Some tests set an invalid AUTH_USER_MODEL.
                   pass
               else:
                   from django.contrib.auth import backends
       
                   backends.UserModel = UserModel
       
                   from django.contrib.auth import forms
       
                   forms.UserModel = UserModel
       
                   from django.contrib.auth.handlers import modwsgi
       
                   modwsgi.UserModel = UserModel
       
                   from django.contrib.auth.management.commands import changepassword
       
                   changepassword.UserModel = UserModel
       
                   from django.contrib.auth import views
       
                   views.UserModel = UserModel
