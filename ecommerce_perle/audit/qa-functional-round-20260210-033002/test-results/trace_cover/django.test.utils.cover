                               suffix=str(index + 1),
                               verbosity=verbosity,
                               keepdb=keepdb,
                           )
    1:             connection.creation.destroy_test_db(old_name, verbosity, keepdb)
       
       
    1: def get_runner(settings, test_runner_class=None):
    2:     test_runner_class = test_runner_class or settings.TEST_RUNNER
    2:     test_path = test_runner_class.split(".")
