       ]
       
       
    2: class RangeWidget(MultiWidget):
    1:     def __init__(self, base_widget, attrs=None):
               widgets = (base_widget, base_widget)
               super().__init__(widgets, attrs)
       
    1:     def decompress(self, value):
               if value:
                   return (value.lower, value.upper)
               return (None, None)
       
       
    2: class HiddenRangeWidget(RangeWidget):
    1:     """A widget that splits input into two <input type="hidden"> inputs."""
       
