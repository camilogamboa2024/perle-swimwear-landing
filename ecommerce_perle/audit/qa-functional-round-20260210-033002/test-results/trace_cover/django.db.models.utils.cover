    1: def make_model_tuple(model):
           """
           Take a model or a string of the form "app_label.ModelName" and return a
           corresponding ("app_label", "modelname") tuple. If a tuple is passed in,
           assume it's a valid model tuple already and return it unchanged.
           """
 1162:     try:
 1162:         if isinstance(model, tuple):
                   model_tuple = model
 1162:         elif isinstance(model, str):
  546:             app_label, model_name = model.split(".")
  546:             model_tuple = app_label, model_name.lower()
               else:
  616:             model_tuple = model._meta.app_label, model._meta.model_name
 1162:         assert len(model_tuple) == 2
 1162:         return model_tuple
           except (ValueError, AssertionError):
               raise ValueError(
                   "Invalid model reference '%s'. String model references "
                   "must be of the form 'app_label.ModelName'." % model
               )
       
       
    1: def resolve_callables(mapping):
           """
           Generate key/value pairs for the given mapping where the values are
           evaluated if they're callable.
           """
  173:     for k, v in mapping.items():
  104:         yield k, v() if callable(v) else v
       
       
    1: def unpickle_named_row(names, values):
           return create_namedtuple_class(*names)(*values)
       
       
    2: @functools.lru_cache
    2: def create_namedtuple_class(*names):
           # Cache type() with @lru_cache since it's too slow to be called for every
           # QuerySet evaluation.
           def __reduce__(self):
               return unpickle_named_row, (names, tuple(self))
       
           return type(
               "Row",
               (namedtuple("Row", names),),
               {"__reduce__": __reduce__, "__slots__": ()},
           )
       
       
    2: class AltersData:
    1:     """
           Make subclasses preserve the alters_data attribute on overridden methods.
           """
       
    1:     def __init_subclass__(cls, **kwargs):
 1517:         for fn_name, fn in vars(cls).items():
 1146:             if callable(fn) and not hasattr(fn, "alters_data"):
  513:                 for base in cls.__bases__:
  316:                     if base_fn := getattr(base, fn_name, None):
   67:                         if hasattr(base_fn, "alters_data"):
    3:                             fn.alters_data = base_fn.alters_data
   67:                         break
       
  371:         super().__init_subclass__(**kwargs)
