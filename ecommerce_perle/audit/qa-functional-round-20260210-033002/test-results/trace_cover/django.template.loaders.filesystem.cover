    1: """
       Wrapper for loading templates from the filesystem.
       """
       
    1: from django.core.exceptions import SuspiciousFileOperation
    1: from django.template import Origin, TemplateDoesNotExist
    1: from django.utils._os import safe_join
       
    1: from .base import Loader as BaseLoader
       
       
    2: class Loader(BaseLoader):
    1:     def __init__(self, engine, dirs=None):
    2:         super().__init__(engine)
    2:         self.dirs = dirs
       
    1:     def get_dirs(self):
    5:         return self.dirs if self.dirs is not None else self.engine.dirs
       
    1:     def get_contents(self, origin):
    5:         try:
   10:             with open(origin.name, encoding=self.engine.file_charset) as fp:
    5:                 return fp.read()
               except FileNotFoundError:
                   raise TemplateDoesNotExist(origin)
       
    1:     def get_template_sources(self, template_name):
               """
               Return an Origin object pointing to an absolute path in each directory
               in template_dirs. For security reasons, if a path doesn't lie inside
               one of the template_dirs it is excluded from the result set.
               """
    5:         for template_dir in self.get_dirs():
    5:             try:
    5:                 name = safe_join(template_dir, template_name)
                   except SuspiciousFileOperation:
                       # The joined path was located outside of this template_dir
                       # (it might be inside another one, so this isn't fatal).
                       continue
       
   10:             yield Origin(
    5:                 name=name,
    5:                 template_name=template_name,
    5:                 loader=self,
                   )
