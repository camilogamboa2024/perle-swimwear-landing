    1:     def __call__(self, *args, **kwargs):
               return IndexTransform(self.index, self.base_field, *args, **kwargs)
       
       
    2: class SliceTransform(Transform):
    1:     def __init__(self, start, end, *args, **kwargs):
               super().__init__(*args, **kwargs)
               self.start = start
               self.end = end
       
    1:     def as_sql(self, compiler, connection):
               lhs, params = compiler.compile(self.lhs)
               # self.start is set to 1 if slice start is not provided.
               if self.end is None:
                   return f"({lhs})[%s:]", (*params, self.start)
               else:
                   return f"({lhs})[%s:%s]", (*params, self.start, self.end)
       
       
    2: class SliceTransformFactory:
    1:     def __init__(self, start, end):
               self.start = start
               self.end = end
       
    1:     def __call__(self, *args, **kwargs):
