       # Levels
    1: DEBUG = 10
    1: INFO = 20
    1: WARNING = 30
    1: ERROR = 40
    1: CRITICAL = 50
       
       
    2: class CheckMessage:
    1:     def __init__(self, level, msg, hint=None, obj=None, id=None):
   30:         if not isinstance(level, int):
                   raise TypeError("The first argument should be level.")
   30:         self.level = level
   30:         self.msg = msg
   30:         self.hint = hint
   30:         self.obj = obj
   30:         self.id = id
       
    1:     def __eq__(self, other):
               return isinstance(other, self.__class__) and all(
                   getattr(self, attr) == getattr(other, attr)
                   for attr in ["level", "msg", "hint", "obj", "id"]
               )
       
    1:     def __str__(self):
               from django.db import models
       
               if self.obj is None:
                   obj = "?"
               elif isinstance(self.obj, models.base.ModelBase):
                   # We need to hardcode ModelBase and Field cases because its __str__
                   # method doesn't return "applabel.modellabel" and cannot be changed.
                   obj = self.obj._meta.label
               else:
                   obj = str(self.obj)
               id = "(%s) " % self.id if self.id else ""
               hint = "\n\tHINT: %s" % self.hint if self.hint else ""
               return "%s: %s%s%s" % (obj, id, self.msg, hint)
       
    1:     def __repr__(self):
               return "<%s: level=%r, msg=%r, hint=%r, obj=%r, id=%r>" % (
                   self.__class__.__name__,
                   self.level,
                   self.msg,
                   self.hint,
                   self.obj,
                   self.id,
               )
       
    1:     def is_serious(self, level=ERROR):
               return self.level >= level
       
    1:     def is_silenced(self):
               from django.conf import settings
       
               return self.id in settings.SILENCED_SYSTEM_CHECKS
       
       
    2: class Debug(CheckMessage):
    1:     def __init__(self, *args, **kwargs):
               super().__init__(DEBUG, *args, **kwargs)
       
       
    2: class Info(CheckMessage):
    1:     def __init__(self, *args, **kwargs):
               super().__init__(INFO, *args, **kwargs)
       
       
    2: class Warning(CheckMessage):
    1:     def __init__(self, *args, **kwargs):
   21:         super().__init__(WARNING, *args, **kwargs)
       
       
    2: class Error(CheckMessage):
    1:     def __init__(self, *args, **kwargs):
    9:         super().__init__(ERROR, *args, **kwargs)
       
       
    2: class Critical(CheckMessage):
    1:     def __init__(self, *args, **kwargs):
               super().__init__(CRITICAL, *args, **kwargs)
