    2: class SearchConfig(Expression):
    1:     def __init__(self, config):
               super().__init__()
               if not hasattr(config, "resolve_expression"):
                   config = Value(config)
               self.config = config
       
    2:     @classmethod
    2:     def from_parameter(cls, config):
               if config is None or isinstance(config, cls):
                   return config
               return cls(config)
       
    1:     def get_source_expressions(self):
               return [self.config]
       
    1:     def set_source_expressions(self, exprs):
               (self.config,) = exprs
       
    1:     def as_sql(self, compiler, connection):
               sql, params = compiler.compile(self.config)
               return "%s::regconfig" % sql, params
       
       
    2: class SearchVectorCombinable:
    1:     ADD = "||"
       
    1:     def _combine(self, other, connector, reversed):
               if not isinstance(other, SearchVectorCombinable):
                   raise TypeError(
                       "SearchVector can only be combined with other SearchVector "
                       "instances, got %s." % type(other).__name__
                   )
               if reversed:
                   return CombinedSearchVector(other, connector, self, self.config)
               return CombinedSearchVector(self, connector, other, self.config)
       
       
    2: register_combinable_fields(
    1:     SearchVectorField, SearchVectorCombinable.ADD, SearchVectorField, SearchVectorField
