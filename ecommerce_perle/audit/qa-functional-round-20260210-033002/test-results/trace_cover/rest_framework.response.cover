    1: from django.template.response import SimpleTemplateResponse
       
    1: from rest_framework.serializers import Serializer
       
       
    2: class Response(SimpleTemplateResponse):
    1:     """
           An HttpResponse that allows its data to be rendered into
           arbitrary media types.
           """
       
    2:     def __init__(self, data=None, status=None,
    1:                  template_name=None, headers=None,
    1:                  exception=False, content_type=None):
               """
               Alters the init arguments slightly.
               For example, drop 'template_name', and instead use 'data'.
       
               Setting 'renderer' and 'media_type' will typically be deferred,
               For example being set automatically by the `APIView`.
