   10: def config(
    2:     env: str = DEFAULT_ENV,
    2:     default: Optional[str] = None,
    2:     engine: Optional[str] = None,
    2:     conn_max_age: Optional[int] = 0,
    2:     conn_health_checks: bool = False,
    2:     disable_server_side_cursors: bool = False,
