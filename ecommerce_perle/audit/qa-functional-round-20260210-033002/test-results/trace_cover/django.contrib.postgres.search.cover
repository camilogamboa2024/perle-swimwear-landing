    2: class SearchQueryCombinable:
    1:     BITAND = "&&"
    1:     BITOR = "||"
       
    1:     def _combine(self, other, connector, reversed):
               if not isinstance(other, SearchQueryCombinable):
                   raise TypeError(
                       "SearchQuery can only be combined with other SearchQuery "
                       "instances, got %s." % type(other).__name__
                   )
               if reversed:
                   return CombinedSearchQuery(other, connector, self, self.config)
               return CombinedSearchQuery(self, connector, other, self.config)
       
           # On Combinable, these are not implemented to reduce confusion with Q. In
           # this case we are actually (ab)using them to do logical combination so
           # it's consistent with other usage in Django.
    1:     def __or__(self, other):
               return self._combine(other, self.BITOR, False)
       
    1:     def __ror__(self, other):
               return self._combine(other, self.BITOR, True)
       
    1:     def __and__(self, other):
               return self._combine(other, self.BITAND, False)
       
    1:     def __rand__(self, other):
               return self._combine(other, self.BITAND, True)
       
       
    2: class SearchQuery(SearchQueryCombinable, Func):
    1:     output_field = SearchQueryField()
    1:     SEARCH_TYPES = {
    1:         "plain": "plainto_tsquery",
    1:         "phrase": "phraseto_tsquery",
    1:         "raw": "to_tsquery",
    1:         "websearch": "websearch_to_tsquery",
           }
       
    2:     def __init__(
               self,
               value,
    1:         output_field=None,
               *,
    1:         config=None,
    1:         invert=False,
    1:         search_type="plain",
           ):
               self.function = self.SEARCH_TYPES.get(search_type)
               if self.function is None:
                   raise ValueError("Unknown search_type argument '%s'." % search_type)
               if not hasattr(value, "resolve_expression"):
                   value = Value(value)
               expressions = (value,)
               self.config = SearchConfig.from_parameter(config)
               if self.config is not None:
                   expressions = (self.config,) + expressions
               self.invert = invert
               super().__init__(*expressions, output_field=output_field)
       
    1:     def as_sql(self, compiler, connection, function=None, template=None):
               sql, params = super().as_sql(compiler, connection, function, template)
               if self.invert:
                   sql = "!!(%s)" % sql
               return sql, params
       
    1:     def __invert__(self):
               clone = self.copy()
               clone.invert = not self.invert
               return clone
       
    1:     def __str__(self):
               result = super().__str__()
               return ("~%s" % result) if self.invert else result
       
       
    2: class CombinedSearchQuery(SearchQueryCombinable, CombinedExpression):
    1:     def __init__(self, lhs, connector, rhs, config, output_field=None):
               self.config = config
               super().__init__(lhs, connector, rhs, output_field)
       
    1:     def __str__(self):
               return "(%s)" % super().__str__()
       
       
    2: class SearchRank(Func):
    1:     function = "ts_rank"
    1:     output_field = FloatField()
       
    1:     def __init__(
               self,
               vector,
               query,
    1:         weights=None,
    1:         normalization=None,
    1:         cover_density=False,
           ):
               from .fields.array import ArrayField
       
               if not hasattr(vector, "resolve_expression"):
                   vector = SearchVector(vector)
               if not hasattr(query, "resolve_expression"):
                   query = SearchQuery(query)
               expressions = (vector, query)
               if weights is not None:
                   if not hasattr(weights, "resolve_expression"):
                       weights = Value(weights)
                   weights = Cast(weights, ArrayField(_Float4Field()))
                   expressions = (weights,) + expressions
               if normalization is not None:
                   if not hasattr(normalization, "resolve_expression"):
                       normalization = Value(normalization)
                   expressions += (normalization,)
               if cover_density:
                   self.function = "ts_rank_cd"
               super().__init__(*expressions)
       
       
    2: class SearchHeadline(Func):
    1:     function = "ts_headline"
    1:     template = "%(function)s(%(expressions)s%(options)s)"
    1:     output_field = TextField()
       
    1:     def __init__(
               self,
               expression,
               query,
               *,
    1:         config=None,
    1:         start_sel=None,
    1:         stop_sel=None,
    1:         max_words=None,
    1:         min_words=None,
    1:         short_word=None,
    1:         highlight_all=None,
    1:         max_fragments=None,
    1:         fragment_delimiter=None,
           ):
               if not hasattr(query, "resolve_expression"):
                   query = SearchQuery(query)
               options = {
                   "StartSel": start_sel,
                   "StopSel": stop_sel,
                   "MaxWords": max_words,
                   "MinWords": min_words,
                   "ShortWord": short_word,
                   "HighlightAll": highlight_all,
                   "MaxFragments": max_fragments,
                   "FragmentDelimiter": fragment_delimiter,
               }
               self.options = {
                   option: value for option, value in options.items() if value is not None
               }
               expressions = (expression, query)
               if config is not None:
                   config = SearchConfig.from_parameter(config)
                   expressions = (config,) + expressions
               super().__init__(*expressions)
       
    1:     def as_sql(self, compiler, connection, function=None, template=None):
               options_sql = ""
               options_params = []
               if self.options:
                   options_params.append(
                       ", ".join(
                           connection.ops.compose_sql(f"{option}=%s", [value])
                           for option, value in self.options.items()
                       )
                   )
                   options_sql = ", %s"
               sql, params = super().as_sql(
                   compiler,
                   connection,
                   function=function,
                   template=template,
                   options=options_sql,
               )
               return sql, params + options_params
       
       
