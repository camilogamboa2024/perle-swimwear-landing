    1: from django.test import TestCase, override_settings
       
    1: from apps.catalog.models import Category, Product, ProductVariant
    1: from apps.inventory.models import StockLevel
       
       
    2: class WhatsAppVisibilityTemplateTest(TestCase):
    2:     @override_settings(WHATSAPP_PHONE='')
    2:     def test_home_hides_wa_links_when_phone_empty(self):
    1:         response = self.client.get('/')
    1:         self.assertEqual(response.status_code, 200)
    1:         self.assertNotContains(response, 'wa.me/')
       
    2:     @override_settings(WHATSAPP_PHONE='573001112233')
    2:     def test_home_shows_wa_links_when_phone_set(self):
    1:         response = self.client.get('/')
    1:         self.assertEqual(response.status_code, 200)
