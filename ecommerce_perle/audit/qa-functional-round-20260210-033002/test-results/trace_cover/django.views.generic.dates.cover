    2: class BaseDayArchiveView(YearMixin, MonthMixin, DayMixin, BaseDateListView):
    1:     """
           Base view for a list of objects published on a given day.
       
           This requires subclassing to provide a response mixin.
           """
       
    1:     def get_dated_items(self):
               """Return (date_list, items, extra_context) for this request."""
               year = self.get_year()
               month = self.get_month()
               day = self.get_day()
       
               date = _date_from_string(
                   year,
                   self.get_year_format(),
                   month,
                   self.get_month_format(),
                   day,
                   self.get_day_format(),
               )
       
