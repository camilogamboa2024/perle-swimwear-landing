    1: import functools
    1: import uuid
    1: import warnings
       
    1: from django.utils.deprecation import RemovedInDjango60Warning
       
       
    2: class IntConverter:
    1:     regex = "[0-9]+"
       
    1:     def to_python(self, value):
    3:         return int(value)
       
    1:     def to_url(self, value):
               return str(value)
       
       
    2: class StringConverter:
    1:     regex = "[^/]+"
       
    1:     def to_python(self, value):
    2:         return value
       
    1:     def to_url(self, value):
               return value
       
       
    2: class UUIDConverter:
