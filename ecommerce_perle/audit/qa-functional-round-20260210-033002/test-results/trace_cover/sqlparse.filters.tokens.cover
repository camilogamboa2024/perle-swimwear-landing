    1: from sqlparse import tokens as T
       
       
    2: class _CaseFilter:
    1:     ttype = None
       
    1:     def __init__(self, case=None):
               case = case or 'upper'
               self.convert = getattr(str, case)
       
    1:     def process(self, stream):
               for ttype, value in stream:
                   if ttype in self.ttype:
                       value = self.convert(value)
                   yield ttype, value
       
       
    2: class KeywordCaseFilter(_CaseFilter):
    1:     ttype = T.Keyword
       
       
    2: class IdentifierCaseFilter(_CaseFilter):
    1:     ttype = T.Name, T.String.Symbol
       
    1:     def process(self, stream):
               for ttype, value in stream:
                   if ttype in self.ttype and value.strip()[0] != '"':
                       value = self.convert(value)
                   yield ttype, value
       
       
    2: class TruncateStringFilter:
    1:     def __init__(self, width, char):
               self.width = width
               self.char = char
       
    1:     def process(self, stream):
               for ttype, value in stream:
                   if ttype != T.Literal.String.Single:
                       yield ttype, value
                       continue
       
                   if value[:2] == "''":
                       inner = value[2:-2]
                       quote = "''"
                   else:
                       inner = value[1:-1]
                       quote = "'"
       
                   if len(inner) > self.width:
                       value = ''.join((quote, inner[:self.width], self.char, quote))
                   yield ttype, value
