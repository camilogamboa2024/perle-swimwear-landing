    2: class CheckoutConfirmApiViewTest(TestCase):
    1:     def setUp(self):
    5:         self.client = Client(enforce_csrf_checks=True)
    5:         category = Category.objects.create(name='One Piece', slug='one-piece')
    5:         product = Product.objects.create(name='Model', slug='model', category=category, description='x')
   10:         self.variant = ProductVariant.objects.create(
    5:             product=product, sku='SKU-API-1', size='M', color='Negro', price_cop=150000
               )
    5:         StockLevel.objects.update_or_create(variant=self.variant, defaults={'available': 1})
       
    1:     def _csrf_headers(self, path='/'):
    8:         response = self.client.get(path)
    8:         token = response.cookies.get('csrftoken').value
    8:         return {'HTTP_X_CSRFTOKEN': token}
       
    1:     def _payload(self, email):
    6:         return {
    6:             'full_name': 'Cliente API',
    6:             'email': email,
    6:             'phone': '',
    6:             'line1': 'Calle 123',
    6:             'city': 'Bogotá',
    6:             'state': 'DC',
    6:             'coupon_code': '',
    6:             'payment_method': 'whatsapp',
               }
       
    1:     def _add_to_cart(self, quantity):
    3:         headers = self._csrf_headers('/')
   12:         return self.client.post(
    3:             '/api/cart/items/',
    3:             data=json.dumps({'variant_id': self.variant.id, 'quantity': quantity}),
    3:             content_type='application/json',
    3:             **headers,
               )
       
    1:     def _confirm_checkout(self, email, with_csrf=True):
    6:         headers = self._csrf_headers('/checkout/') if with_csrf else {}
   24:         return self.client.post(
    6:             '/checkout/api/checkout/confirm/',
    6:             data=json.dumps(self._payload(email)),
    6:             content_type='application/json',
    6:             **headers,
               )
       
    1:     def test_empty_cart_returns_400_and_rolls_back_customer_data(self):
    1:         response = self._confirm_checkout('empty-cart@example.com')
    1:         self.assertEqual(response.status_code, 400)
    1:         self.assertIn('vacío', response.json().get('error', '').lower())
    1:         self.assertFalse(Customer.objects.filter(email='empty-cart@example.com').exists())
    1:         self.assertFalse(Address.objects.exists())
       
    1:     def test_out_of_stock_returns_400_and_rolls_back_customer_data(self):
    1:         add_response = self._add_to_cart(quantity=1)
    1:         self.assertEqual(add_response.status_code, 201)
    1:         StockLevel.objects.filter(variant=self.variant).update(available=0)
       
    1:         response = self._confirm_checkout('out-of-stock@example.com')
    1:         self.assertEqual(response.status_code, 400)
    1:         self.assertIn('sin stock', response.json().get('error', '').lower())
    1:         self.assertFalse(Customer.objects.filter(email='out-of-stock@example.com').exists())
    1:         self.assertFalse(Address.objects.exists())
       
    1:     def test_missing_stock_level_returns_400(self):
    1:         add_response = self._add_to_cart(quantity=1)
    1:         self.assertEqual(add_response.status_code, 201)
    1:         self.variant.stock_level.delete()
       
    1:         response = self._confirm_checkout('missing-stock@example.com')
    1:         self.assertEqual(response.status_code, 400)
    1:         self.assertIn('stock configurado', response.json().get('error', '').lower())
    1:         self.assertFalse(Customer.objects.filter(email='missing-stock@example.com').exists())
    1:         self.assertFalse(Address.objects.exists())
       
    1:     def test_checkout_confirm_requires_csrf_token(self):
    1:         response = self._confirm_checkout('missing-csrf@example.com', with_csrf=False)
    1:         self.assertEqual(response.status_code, 403)
       
    1:     def test_double_submit_returns_400_on_second_attempt_and_keeps_single_order(self):
    1:         add_response = self._add_to_cart(quantity=1)
    1:         self.assertEqual(add_response.status_code, 201)
       
    1:         first_response = self._confirm_checkout('double-submit@example.com')
    1:         self.assertEqual(first_response.status_code, 201)
       
    1:         second_response = self._confirm_checkout('double-submit@example.com')
    1:         self.assertEqual(second_response.status_code, 400)
    1:         self.assertIn('vacío', second_response.json().get('error', '').lower())
    1:         self.assertEqual(Order.objects.filter(customer__email='double-submit@example.com').count(), 1)
